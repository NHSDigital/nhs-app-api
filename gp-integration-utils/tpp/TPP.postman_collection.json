		{
			"name": "(2) - Authenticate",
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"// Extract the session id from the header and store it",
							"pm.environment.set(\"Suid\", postman.getResponseHeader(\"suid\"));",
							"",
							"// Extract the patient id from the return body and store it",
							"var jsonObject = xml2Json(responseBody);",
							"pm.environment.set(\"PatientId\", jsonObject['AuthenticateReply']['$']['patientId']);",
							"pm.environment.set(\"OnlineUserId\", jsonObject['AuthenticateReply']['$']['onlineUserId']);"
						]
					}
				}
			],
			"request": {
				"auth": {
					"type": "noauth"
				},
				"method": "POST",
				"header": [
					{
						"key": "Content-Type",
						"value": "text/xml"
					},
					{
						"key": "type",
						"value": "Authenticate"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "<Authenticate apiVersion=\"{{ApiVersion}}\" accountId=\"{{AccountId}}\" passphrase=\"{{UserApiPassphrase}}\" unitId=\"{{UnitId}}\" uuid=\"{{$guid}}\">\n\t<Application name=\"NhsApp\" version=\"1.0\" providerId=\"{{ProviderId}}\" deviceType=\"NhsApp\"></Application>\n</Authenticate>"
				},
				"url": {
					"raw": "{{TppApiUrl}}",
					"host": [
						"{{TppApiUrl}}"
					]
				}
			},
			"response": []
		},
