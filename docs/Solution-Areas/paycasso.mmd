graph TD
  Start --> jsm
  jsm(JS Method Called) --> psc
  psc(Paycasso Service Called) --> jus
  jus(Journey UI Shown) --> uct
  uct{User Selects Cancel?} -- yes --> ofc
  uct -- no --> edj
  edj{Error During Journey?} -- yes --> ofc
  edj -- no --> osc
  ofc(On Failure Called) --> juc
  osc(On Success Called) --> juc
  juc(Journey UI Closed)

