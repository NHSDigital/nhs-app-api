  nhsl("NHS Login #40;Client#41;") -.-> jsapi
  jsapi(JavaScript API) --> app
  app(NHS App) -.-> pc
    pc(Paycasso) --> ps
      ps(SDK) -.-> papi(REST API)
    pc --> vl(View Library)
