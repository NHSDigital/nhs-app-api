ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://*:8082
ConfigurationSettings__CookieDomain=.bitraft.io
ConfigurationSettings__DefaultSessionExpiryMinutes=10
CORS_AUTHORITY=*
DELAY_AFTER_NOMINATED_PHARMACY_UPDATE_IN_MILLISECONDS=500
GP_PRACTICE_ODS_CODE_FOR_EPS_ENABLED_CHECK_OVERRIDE=B83054
NOMINATED_PHARMACY_ENABLED=true
PHARMACY_API_RESULT_LIMIT=10
ONLINE_PHARMACY_RANDOMISED_SEARCH_RESULT_LIMIT=10
ONLINE_PHARMACY_SEARCH_RESULT_LIMIT=20
PORT=8082
POSTCODE_LOOKUP_SEARCH_RADIUS_KM=10
PROXY_ACCESS_ENABLED=true
KNOWNSERVICES_PATH=KnownServices.json
NHS_WEB_APP_BASE_URL=http://web.local.bitraft.io:3000
ODS_REMAP_ENABLED=false
ODS_REMAP_MAP=
CONSENT_MONGO_DATABASE_COLLECTION=consent
CONSENT_MONGO_DATABASE_NAME=development
AUDIT_MONGO_DATABASE_NAME=development
AUDIT_MONGO_DATABASE_COLLECTION=audit_info
AUDIT_MONGO_CONNECTION_STRING=mongodb://nhsonline.mongodb:27017