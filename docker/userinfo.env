ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://*:8091
CORS_AUTHORITY=*
NHSAPP_API_KEY=/run/secrets/nhsapp_api_key
PORT=8091
MONGO_CONNECTION_STRING=mongodb://mongodb.bitraft.io:27017
COSMOS_SQL_API_CONNECTION_STRING=/run/secrets/cosmos_sql_api_connection_string
AUDIT_SINK_TYPE=cosmosdb
AUDIT_EVENT_HUB_CONNECTION_STRING=/run/secrets/audit_event_hub_connection_string
AUDIT_EVENT_HUB_NAME=eventhub_ns_auditing
AUDIT_MONGO_DATABASE_COLLECTION=audit_info
USERINFO_MONGO_DATABASE_COLLECTION=info
USERINFO_NHS_NUMBER_CONTAINER=info_nhs_number
USERINFO_ODS_CODE_CONTAINER=info_ods_code
MONGO_DATABASE_NAME=development
COMMS_SQL_API_DATABASE_NAME=comms-dev-sql
VERSION_TAG=userinfo_docker_main
ENVIRONMENT_NAME=test
