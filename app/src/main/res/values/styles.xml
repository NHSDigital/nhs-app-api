<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="menu_default_text" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/defaultMenuTextColor</item>
        <item name="android:textSize">@dimen/menuBarItemFontSize</item>
    </style>

    <style name="default_warning_text" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/_16ssp</item>
        <item name="android:padding">@dimen/_4sdp</item>
        <item name="android:background">@drawable/warning_border</item>
    </style>

    <style name="blue_button" parent="Base.TextAppearance.AppCompat.Button">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:background">@color/nhsBlue</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">@dimen/errorTextSize</item>
    </style>
</resources>
