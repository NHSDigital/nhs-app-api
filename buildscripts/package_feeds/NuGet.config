<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>

  <packageSourceCredentials>
    <nhsapp-nuget-feed>
      <add key="Username" value="nhsapp" />
      <add key="ClearTextPassword" value="<TOKEN>" />
    </nhsapp-nuget-feed>
  </packageSourceCredentials>
</configuration>