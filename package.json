{
  "name": "nhsonline-web",
  "version": "1.0.0",
  "description": "NHS Online Web",
  "private": true,
  "scripts": {
    "serve": "node server.js",
    "dev": "npm run swagger && concurrently --kill-others \"npm run serve\" \"cross-env webpack-dev-server --inline --disable-host-check --progress --config build/webpack.dev.conf.js\" ",
    "build": "npm run swagger && node build/build.js",
    "e2e": " node test/e2e/runner.js",
    "test": "npm run e2e",
    "lint": "eslint --ext .js,.vue src test/unit/specs test/e2e/specs",
    "swagger": "node build/swagger.js --contract_path contracts/index.yaml --output_path src/services/nhsonlineapi.js"
  },
  "dependencies": {
    "vue": "^2.5.2"
  },
