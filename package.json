{
  "name": "nhsonline-web",
  "version": "1.0.0",
  "private": true,
  "description": "NHS Online Web",
  "main": "index.js",
  "scripts": {
    "dev": "npm run swagger && nuxt",
    "build": "npm run swagger && nuxt build",
    "start": "nuxt start",
    "swagger": "node build/swagger.js --contract_path contracts/index.yaml --output_path src/services/nhsonlineapi.js",
    "test": "jest --coverage",
    "test-watch": "jest --watchAll",
    "lint": "eslint --ext .js,.vue .",
    "lintfix": "eslint --fix --ext .js,.vue .",
    "generate": "npm run swagger && nuxt generate"
  },
  "precommit": "npm run lint",
  "author": "",
  "license": "ISC",
  "jest": {
    "verbose": true,
    "moduleFileExtensions": [
      "js",
      "vue"
    ],
    "transform": {
      "^.+\\.js$": "<rootDir>/node_modules/babel-jest",
      ".*\\.(vue)$": "<rootDir>/node_modules/jest-vue-preprocessor"
    }
  },
  "dependencies": {
    "axios": "^0.18.0",
    "babel-core": "^6.26.3",
    "babel-eslint": "^8.2.3",
    "babel-jest": "^22.4.3",
    "babel-plugin-dynamic-import-node": "^1.2.0",
    "babel-plugin-transform-es2015-modules-commonjs": "^6.26.2",
    "babel-plugin-transform-runtime": "^6.23.0",
    "babel-plugin-transform-vue-jsx": "^3.7.0",
    "babel-preset-env": "^1.7.0",
    "babel-preset-es2015": "^6.24.1",
    "babel-preset-stage-2": "^6.24.1",
    "circular-json": "^0.5.3",
    "cookie": "^0.3.1",
    "cookie-universal-nuxt": "^2.0.3",
    "crypto": "^1.0.1",
    "eslint-config-airbnb-base": "^12.1.0",
    "eslint-plugin-import": "^2.12.0",
    "fs": "0.0.1-security",
    "js-cookie": "^2.2.0",
    "js-yaml": "^3.11.0",
    "lodash": "^4.17.10",
    "minimist": "^1.2.0",
    "moment": "^2.22.1",
    "node-sass": "^4.9.0",
    "nuxt": "^1.4.0",
    "sass-loader": "^7.0.1",
    "swagger-js-codegen": "^1.12.0",
    "vue-i18n": "^7.6.0",
    "vuex-persistedstate": "^2.5.2"
  },
  "devDependencies": {
    "@types/jest": "^22.2.3",
    "@vue/test-utils": "^1.0.0-beta.16",
    "avoriaz": "^6.3.0",
    "eslint": "^4.19.1",
    "eslint-loader": "^2.0.0",
    "eslint-plugin-vue": "^4.5.0",
    "jest": "^22.4.3",
    "jest-serializer-vue": "^1.0.0",
    "jest-vue-preprocessor": "^1.4.0",
    "vue-jest": "^2.5.0",
    "vuex": "^3.0.1",
    "vuex-persist": "^1.2.2"
  }
}
