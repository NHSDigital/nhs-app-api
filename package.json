{
  "name": "nhsonline-web",
  "version": "1.0.0",
  "description": "NHS Online Web",
  "private": true,
  "scripts": {
    "start": "node server.js",
    "serve": "node server.js",
    "dev": "npm run swagger && npm run lint && concurrently --kill-others \"npm run serve\" \"webpack-dev-server --inline --disable-host-check --progress --config build/webpack.dev.conf.js\" ",
    "build": "npm run swagger && node build/build.js",
    "test": "npm run test-unit",
    "test-unit": "npm run lint && jest --config test/unit/jest.conf.js --coverage",
    "test-unit-watch": "jest --config test/unit/jest.conf.js --watchAll",
    "lint": "eslint --ext .js,.vue src server.js config test/unit",
    "swagger": "node build/swagger.js --contract_path contracts/index.yaml --output_path src/services/nhsonlineapi.js"
  },
  "dependencies": {
    "express": "^4.16.3",
    "path": "^0.12.7"
  },
  "devDependencies": {
    "@openid/appauth": "^0.3.1",
    "@vue/test-utils": "^1.0.0-beta.13",
    "autoprefixer": "^7.1.2",
    "axios": "^0.18.0",
    "babel-core": "^6.22.1",
    "babel-eslint": "^8.2.1",
    "babel-helper-vue-jsx-merge-props": "^2.0.3",
    "babel-jest": "^21.0.2",
    "babel-loader": "^7.1.1",
    "babel-plugin-dynamic-import-node": "^1.2.0",
    "babel-plugin-syntax-jsx": "^6.18.0",
    "babel-plugin-transform-es2015-modules-commonjs": "^6.26.0",
    "babel-plugin-transform-runtime": "^6.22.0",
    "babel-plugin-transform-vue-jsx": "^3.5.0",
    "babel-preset-env": "^1.3.2",
    "babel-preset-stage-2": "^6.22.0",
    "babel-register": "^6.22.0",
    "chalk": "^2.0.1",
    "compression-webpack-plugin": "^1.1.6",
    "concurrently": "^3.5.1",
    "copy-webpack-plugin": "^4.0.1",
    "cross-spawn": "^5.0.1",
    "crypto": "^1.0.1",
    "css-loader": "^0.28.0",
    "cucumber": "^4.0.0",
    "eslint": "^4.16.0",
    "eslint-config-airbnb-base": "^11.3.0",
    "eslint-friendly-formatter": "^3.0.0",
    "eslint-import-resolver-webpack": "^0.8.3",
    "eslint-loader": "^1.7.1",
    "eslint-plugin-import": "^2.10.0",
    "eslint-plugin-vue": "^4.0.0",
    "extract-text-webpack-plugin": "^3.0.0",
    "file-loader": "^1.1.4",
    "friendly-errors-webpack-plugin": "^1.6.1",
    "fs": "0.0.1-security",
    "html-webpack-plugin": "^2.30.1",
    "jest": "^22.0.4",
    "jest-serializer-vue": "^0.3.0",
    "js-yaml": "^3.10.0",
    "karma": "^2.0.0",
    "lodash": "^4.17.5",
    "minimist": "^1.2.0",
    "node-notifier": "^5.1.2",
    "node-sass": "^4.7.2",
    "npm": "^5.7.1",
    "optimize-css-assets-webpack-plugin": "^3.2.0",
    "ora": "^1.2.0",
    "portfinder": "^1.0.13",
    "postcss": "^6.0.16",
    "postcss-import": "^11.0.0",
    "postcss-loader": "^2.0.8",
    "postcss-url": "^7.2.1",
    "q": "^1.5.1",
    "rimraf": "^2.6.0",
    "sass-loader": "^6.0.6",
    "semver": "^5.3.0",
    "shelljs": "^0.7.6",
    "style-loader": "^0.20.1",
    "swagger-js-codegen": "^1.12.0",
    "uglifyjs-webpack-plugin": "^1.1.1",
    "url-loader": "^0.5.8",
    "vue": "^2.5.2",
    "vue-i18n": "^7.4.2",
    "vue-jest": "^1.0.2",
    "vue-loader": "^13.7.1",
    "vue-router": "^3.0.1",
    "vue-style-loader": "^3.0.1",
    "vue-template-compiler": "^2.5.2",
    "vuex": "^3.0.1",
    "vuex-router-sync": "^5.0.0",
    "webpack": "^3.6.0",
    "webpack-bundle-analyzer": "^2.9.0",
    "webpack-dev-server": "^2.9.1",
    "webpack-merge": "^4.1.0"
  },
  "engines": {
    "node": ">= 6.0.0",
    "npm": ">= 3.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not ie <= 8"
  ],
  "babel": {
    "presets": [
      "stage-3",
      "latest"
    ]
  }
}
