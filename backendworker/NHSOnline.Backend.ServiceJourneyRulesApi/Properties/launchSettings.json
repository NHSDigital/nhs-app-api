{
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "iisSettings": {
    "windowsAuthentication": false, 
    "anonymousAuthentication": true, 
    "iisExpress": {
      "applicationUrl": "http://servicejourneyrulesapi.local.bitraft.io:8086",
      "sslPort": 0
    }
  },
  "profiles": {
    "NHSOnline.Backend.ServiceJourneyRulesApi": {
      "commandName": "Project",
      "launchBrowser": true,
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://*:8086",
        "SESSION_MONGO_DATABASE_HOST": "localhost",
        "SESSION_MONGO_DATABASE_PORT": "27017",
        "SESSION_MONGO_DATABASE_USERNAME": "",
        "SESSION_MONGO_DATABASE_PASSWORD": "",
        "SESSION_MONGO_DATABASE_NAME": "development",
        "SESSION_MONGO_DATABASE_COLLECTION": "session",
        "AUDIT_SINK_TYPE": "FILE",
        "INPUT_FOLDER_PATH": "../configurations/output"
      }
    },
    "Validate": {
      "commandName": "Project",
      "commandLineArgs": "--validate-only",
      "environmentVariables": {
        "GP_INFO_FILE_PATH": "../configurations/gpinfo.csv",
        "CONFIGURATION_FOLDER_PATH": "../configurations",
        "RULES_FOLDER_NAME": "Rules",
        "JOURNEYS_FOLDER_NAME": "Journeys",
        "OUTPUT_FOLDER_PATH": "../configurations/output"
      }
    }
  }
}