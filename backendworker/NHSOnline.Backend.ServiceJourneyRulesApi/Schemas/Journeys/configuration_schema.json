{
  "id": "https://nhsapp.service.nhs.uk/service-journey-rules.schema.json",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "description": "A single rule for the NHS App Journeys",
  "additionalProperties": false,
  "type": "object",
  "definitions": {
    "appointmentsJourney": {
      "oneOf": [{
        "additionalProperties": false,
        "properties": {
          "provider": {
            "enum": [ "im1" ]
          }
        }
      },{
        "additionalProperties": false,
        "properties": {
          "provider": {
            "enum": [ "informatica" ]
          },
          "informaticaUrl": { "type": "string" }
        },
        "required": ["provider", "informaticaUrl"]
      },{
        "additionalProperties": false,
        "properties": {
          "provider": {
            "enum": [ "none" ]
          }
        }
      }]
    },
    "prescriptionsJourney": {
      "oneOf": [{
        "additionalProperties": false,
        "properties": {
          "provider": {
            "enum": [ "im1" ]
          }
        }
      },{
        "additionalProperties": false,
        "properties": {
          "provider": {
            "enum": [ "none" ]
          }
        }
      }]
    },
    "medicalRecordJourney": {
      "oneOf": [{
        "additionalProperties": false,
        "properties": {
          "provider": {
            "enum": [ "im1" ]
          }
        }
      },{
        "additionalProperties": false,
        "properties": {
          "provider": {
            "enum": [ "none" ]
          }
        }
      }]
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "target": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "*": {
              "type": "string",
              "enum": ["*"]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "odsCode": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ccgCode": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "supplier": { "enum": ["emis", "tpp", "vision", "microtest"] }
          }
        }
      ]
    },
    "journeys": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "appointments": { "$ref": "#/definitions/appointmentsJourney" },
        "prescriptions": { "$ref": "#/definitions/prescriptionsJourney" },
        "medicalRecord": { "$ref": "#/definitions/medicalRecordJourney" }
      },
      "anyOf": [{
        "required": ["appointments"]
      },{
        "required": ["prescriptions"]
      },{
        "required": ["medicalRecord"]
      }]
    }
  },
  "required": ["target", "journeys"]
}