{
  "id": "https://nhsapp.service.nhs.uk/service-journey-rules.schema.json",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "description": "A single rule for the NHS App Journeys",
  "additionalProperties": false,
  "type": "object",
  "definitions": {
    "appointmentsJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "im1", "gpAtHand", "eConsult" ]
            }
          },
          "required": [ "provider" ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "informatica" ]
            },
            "informaticaUrl": { "type": "string" }
          },
          "required": [ "provider", "informaticaUrl" ]
        }
      ]
    },
    "cdssAdviceJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "none" ]
            }
          },
          "required": [ "provider" ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "eConsult", "stubs" ]
            },
            "serviceDefinition": { "type": "string" },
            "knownGeneralServiceDefinitions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [ "provider", "serviceDefinition", "knownGeneralServiceDefinitions" ]
        }
      ]
    },
    "cdssAdminJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "none" ]
            }
          },
          "required": [ "provider" ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "eConsult", "stubs" ]
            },
            "serviceDefinition": { "type": "string" },
            "knownGeneralServiceDefinitions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          "required": [ "provider", "serviceDefinition", "knownGeneralServiceDefinitions" ]
        }
      ]
    },
    "homeScreen": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "publicHealthNotifications": {
          "type": "array",
          "minItems": 1,
          "items": {
            "anyOf": [
              {
                "$ref": "#/definitions/publicHealthNotificationCallout"
              }
            ]
          }
        }
      },
      "anyOf": [
        {
          "required": [ "publicHealthNotifications" ]
        }
      ]
    },
    "im1MessagingJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "isEnabled": {
              "enum": ["true"]
            },
            "canDeleteMessages": {
              "enum": ["true", "false"]
            },
            "canUpdateReadStatus": {
              "enum": ["true", "false"]
            },
            "requiresDetailsRequest": {
              "enum": ["true", "false"]
            },
            "sendMessageSubject": {
              "enum": ["true", "false"]
            }
          },
          "required": [
            "isEnabled",
            "canDeleteMessages",
            "canUpdateReadStatus",
            "requiresDetailsRequest",
            "sendMessageSubject"
          ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "isEnabled": {
              "enum": ["false"]
            },
            "canDeleteMessages": {
              "enum": ["false"]
            },
            "canUpdateReadStatus": {
              "enum": ["false"]
            },
            "requiresDetailsRequest": {
              "enum": ["false"]
            },
            "sendMessageSubject": {
              "enum": ["false"]
            }
          },
          "required": ["isEnabled"]
        }
      ]
    },
    "medicalRecordJourney": {
      "properties": {
        "provider": {
          "enum": [ "im1", "gpAtHand" ]
        },
        "version": {
          "type": "string"
        }
      },
      "required": [ "provider", "version" ],
      "additionalProperties": false
    },
    "prescriptionsJourney": {
      "properties": {
        "provider": {
          "enum": [ "im1", "gpAtHand" ]
        }
      },
      "required": [ "provider" ],
      "additionalProperties": false
    },
    "publicHealthNotificationCallout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "[A-Za-z0-9_]+"
        },
        "type": {
          "enum": [ "callout" ]
        },
        "urgency": {
          "enum": [ "warning" ]
        },
        "title": { "type": "string" },
        "body": { "type": "string" }
      },
      "required": [ "id", "type", "urgency", "title", "body" ]
    },
    "silverIntegrations": {
      "properties": {
        "accountAdmin":  {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [ "gncr", "substraktPatientPack"]
          }
        },
        "appointmentBookings":  {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["nbs"]
          }
        },
        "carePlans": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["pkb"]
          }
        },
        "consultations": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [ "pkb", "engage", "accurx", "patchs" ]
          }
        },
        "consultationsAdmin": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [ "engage" ]
          }
        },
        "healthTrackers": {
          "type":"array",
          "items": {
            "type": "string",
            "enum": ["pkb", "wellnessAndPrevention"]
          }
        },
        "libraries": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["pkb"]
          }
        },
        "medicines": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["pkb"]
          }
        },
        "messages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [ "pkb", "testSilverThirdPartyProvider", "engage" , "gncr", "substraktPatientPack", "accurx" ]
          }
        },
        "participation":  {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["substraktPatientPack"]
          }
        },
        "recordSharing": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [ "pkb" ]
          }
        },
        "secondaryAppointments": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [ "ers", "pkb", "gncr", "removeErs"]
          }
        },
        "testResults": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [ "pkb" ]
          }
        },
        "vaccineRecord": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["nhsd", "netCompany", "netCompanyP5", "removeNhsd", "removeNetCompany", "removeNetCompanyP5"]
          }
        }
      },
      "additionalProperties": false
    },
    "wayfinder": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "isEnabled": {
          "enum": ["true", "false"]
        }
      }
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "target": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "*": {
              "type": "string",
              "enum": [ "*" ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "odsCode": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "odsCodes": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ccgCode": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "supplier": { "enum": [ "emis", "tpp", "vision" ] }
          }
        }
      ]
    },
    "journeys": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "appointments": { "$ref": "#/definitions/appointmentsJourney" },
        "cdssAdvice": { "$ref": "#/definitions/cdssAdviceJourney" },
        "cdssAdmin": { "$ref": "#/definitions/cdssAdminJourney" },
        "coronavirusInformation": { "enum": [ "true", "false" ] },
        "documents": { "enum": [ "true", "false" ] },
        "homeScreen": { "$ref": "#/definitions/homeScreen" },
        "im1Messaging": { "$ref": "#/definitions/im1MessagingJourney" },
        "medicalRecord": { "$ref": "#/definitions/medicalRecordJourney" },
        "messaging": { "enum": [ "true", "false" ] },
        "ndop": { "enum": [ "true", "false" ] },
        "nominatedPharmacy": { "enum": [ "true", "false" ] },
        "notifications": { "enum": [ "true", "false" ] },
        "notificationPrompt": { "enum": [ "true", "false" ] },
        "oneOneOne": { "enum": [ "true", "false" ] },
        "prescriptions": { "$ref": "#/definitions/prescriptionsJourney" },
        "silverIntegrations": { "$ref": "#/definitions/silverIntegrations" },
        "supplier": { "enum": [ "Emis", "Fake", "Tpp", "Vision" ] },
        "supportsLinkedProfiles": { "enum": [ "true", "false" ] },
        "userInfo": { "enum": [ "true", "false" ] },
        "wayfinder": { "$ref": "#/definitions/wayfinder" }
      },
      "anyOf": [
        {
          "required": [ "appointments" ]
        },
        {
          "required": [ "cdssAdvice" ]
        },
        {
          "required": [ "cdssAdmin" ]
        },
        {
          "required": [ "coronavirusInformation" ]
        },
        {
          "required": [ "documents" ]
        },
        {
          "required": [ "homeScreen" ]
        },
        {
          "required": [ "im1Messaging" ]
        },
        {
          "required": [ "medicalRecord" ]
        },
        {
          "required": [ "messaging" ]
        },
        {
          "required": [ "ndop" ]
        },
        {
          "required": [ "nominatedPharmacy" ]
        },
        {
          "required": [ "notifications" ]
        },
        {
          "required": [ "notificationPrompt" ]
        },
        {
          "required": [ "oneOneOne" ]
        },
        {
          "required": [ "prescriptions" ]
        },
        {
          "required": [ "silverIntegrations" ]
        },
        {
          "required": [ "supplier" ]
        },
        {
          "required": [ "supportsLinkedProfiles" ]
        },
        {
          "required": [ "userInfo" ]
        },
        {
          "required": [ "wayfinder" ]
        }
      ]
    }
  },
  "required": [ "target", "journeys" ]
}
