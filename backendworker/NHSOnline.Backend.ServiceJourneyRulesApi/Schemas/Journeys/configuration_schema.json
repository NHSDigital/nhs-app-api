{
  "id": "https://nhsapp.service.nhs.uk/service-journey-rules.schema.json",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "description": "A single rule for the NHS App Journeys",
  "additionalProperties": false,
  "type": "object",
  "definitions": {
    "appointmentsJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "im1", "gpAtHand", "eConsult" ]
            }
          },
          "required": [ "provider" ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "informatica" ]
            },
            "informaticaUrl": { "type": "string" }
          },
          "required": [ "provider", "informaticaUrl" ]
        }
      ]
    },
    "cdssAdviceJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "none" ]
            }
          },
          "required": [ "provider" ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "eConsult", "stubs" ]
            },
            "serviceDefinition": { "type": "string" },
            "conditionsServiceDefinition": { "type": "string" }
          },
          "required": [ "provider", "serviceDefinition", "conditionsServiceDefinition" ]
        }
      ]
    },
    "cdssAdminJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "none" ]
            }
          },
          "required": [ "provider" ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "eConsult", "stubs" ]
            },
            "serviceDefinition": { "type": "string" }
          },
          "required": [ "provider", "serviceDefinition" ]
        }
      ]
    },
    "homeScreen": {
      "additionalProperties": false,
      "type": "object",
      "properties": {
        "publicHealthNotifications": {
          "type": "array",
          "minItems": 1,
          "items": {
            "anyOf": [
              {
                "$ref": "#/definitions/publicHealthNotificationCallout"
              }
            ]
          }
        }
      },
      "anyOf": [
        {
          "required": [ "publicHealthNotifications" ]
        }
      ]
    },
    "medicalRecordJourney": {
      "properties": {
        "provider": {
          "enum": [ "im1", "gpAtHand" ]
        },
        "version": {
          "type": "string"
        } 
      },
      "required": [ "provider", "version" ],
      "additionalProperties": false
    },
    "prescriptionsJourney": {
      "properties": {
        "provider": {
          "enum": [ "im1", "gpAtHand" ]
        }
      },
      "required": [ "provider" ],
      "additionalProperties": false
    },
    "publicHealthNotificationCallout": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "[A-Za-z0-9_]+"
        },
        "type": {
          "enum": [ "callout" ]
        },
        "urgency": {
          "enum": [ "warning" ]
        },
        "title": { "type": "string" },
        "body": { "type": "string" }
      },
      "required": [ "id", "type", "urgency", "title", "body" ]
    },
    "silverIntegrations": {
      "properties": {
        "carePlans": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["pkb"]
          }
        },
        "consultations": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [ "pkb" ]
          }
        },
        "healthTrackers": {
          "type":"array",
          "items": {
            "type": "string",
            "enum": ["pkb"]
          }
        },
        "libraries": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["pkb"]
          }
        },
        "medicines": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["pkb"]
          }
        },
        "messages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [ "pkb", "testSilverThirdPartyProvider" ]
          }
        },
        "secondaryAppointments": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [ "ers", "pkb" ]
          }
        }
      },
      "additionalProperties": false
    },
    "im1MessagingJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "isEnabled": {
              "enum": ["true"]
            },
            "canDeleteMessages": {
              "enum": ["true", "false"]
            },
            "canUpdateReadStatus": {
              "enum": ["true", "false"]
            },
            "requiresDetailsRequest": {
              "enum": ["true", "false"]
            },
            "sendMessageSubject": {
              "enum": ["true", "false"]
            }
          },
          "required": [
            "isEnabled",
            "canDeleteMessages",
            "canUpdateReadStatus",
            "requiresDetailsRequest",
            "sendMessageSubject"
          ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "isEnabled": {
              "enum": ["false"]
            },
            "canDeleteMessages": {
              "enum": ["false"]
            },
            "canUpdateReadStatus": {
              "enum": ["false"]
            },
            "requiresDetailsRequest": {
              "enum": ["false"]
            },
            "sendMessageSubject": {
              "enum": ["false"]
            }
          },
          "required": ["isEnabled"]
        }
      ]
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "target": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "*": {
              "type": "string",
              "enum": [ "*" ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "odsCode": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "odsCodes": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ccgCode": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "supplier": { "enum": [ "emis", "tpp", "vision", "microtest" ] }
          }
        }
      ]
    },
    "journeys": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "appointments": { "$ref": "#/definitions/appointmentsJourney" },
        "cdssAdvice": { "$ref": "#/definitions/cdssAdviceJourney" },
        "cdssAdmin": { "$ref": "#/definitions/cdssAdminJourney" },
        "homeScreen": { "$ref": "#/definitions/homeScreen" },
        "medicalRecord": { "$ref": "#/definitions/medicalRecordJourney" },
        "messaging": { "enum": [ "true", "false" ] },
        "nominatedPharmacy": { "enum": [ "true", "false" ] },
        "notifications": { "enum": [ "true", "false" ] },
        "prescriptions": { "$ref": "#/definitions/prescriptionsJourney" },
        "silverIntegrations": { "$ref": "#/definitions/silverIntegrations" },
        "supplier": { "enum": [ "Emis", "Fake", "Tpp", "Vision", "Microtest" ] },
        "userInfo": { "enum": ["true", "false"]  },
        "documents": { "enum": ["true", "false"]  },
        "im1Messaging": { "$ref": "#/definitions/im1MessagingJourney" }
      },
      "anyOf": [
        {
          "required": [ "appointments" ]
        },
        {
          "required": [ "cdssAdvice" ]
        },
        {
          "required": [ "cdssAdmin" ]
        },
        {
          "required": [ "homeScreen" ]
        },
        {
          "required": [ "medicalRecord" ]
        },
        {
          "required": [ "messaging" ]
        },
        {
          "required": [ "nominatedPharmacy" ]
        },
        {
          "required": [ "notifications" ]
        },
        {
          "required": [ "prescriptions" ]
        },
        {
          "required": [ "silverIntegrations" ]
        },
        {
          "required": [ "supplier" ]
        },
        {
          "required": [ "userInfo" ]
        },
        {
          "required": [ "documents" ]
        },
        {
          "required": [ "im1Messaging" ]
        }
      ]
    }
  },
  "required": [ "target", "journeys" ]
}