{
  "id": "https://nhsapp.service.nhs.uk/service-journey-rules.schema.json",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "description": "A single rule for the NHS App Journeys",
  "additionalProperties": false,
  "type": "object",
  "definitions": {
    "appointmentsJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "im1", "gpAtHand", "eConsult" ]
            }
          },
          "required": [ "provider" ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "informatica" ]
            },
            "informaticaUrl": { "type": "string" }
          },
          "required": [ "provider", "informaticaUrl" ]
        }
      ]
    },
    "cdssAdviceJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "none" ]
            }
          },
          "required": [ "provider" ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "eConsult", "stubs" ]
            },
            "serviceDefinition": { "type": "string" },
            "conditionsServiceDefinition": { "type": "string" }
          },
          "required": [ "provider", "serviceDefinition", "conditionsServiceDefinition" ]
        }
      ]
    },
    "cdssAdminJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "none" ]
            }
          },
          "required": [ "provider" ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "eConsult", "stubs" ]
            },
            "serviceDefinition": { "type": "string" }
          },
          "required": [ "provider", "serviceDefinition" ]
        }
      ]
    },
    "medicalRecordJourney": {
      "properties": {
        "provider": {
          "enum": [ "im1", "gpAtHand" ]
        },
        "version": {
          "type": "string"
        } 
      },
      "required": [ "provider", "version" ],
      "additionalProperties": false
    },
    "prescriptionsJourney": {
      "properties": {
        "provider": {
          "enum": [ "im1", "gpAtHand" ]
        }
      },
      "required": [ "provider" ],
      "additionalProperties": false
    },
    "silverIntegrations": {
      "properties": {
        "secondaryAppointments": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [ "ers", "pkb" ]
          }
        },
        "messages": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [ "pkb" ]
          }
        },
        "consultations": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [ "pkb" ]
          }
        }
      },
      "required": [ "secondaryAppointments", "messages", "consultations" ],
      "additionalProperties": false
    },
    "im1MessagingJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "isEnabled": {
              "enum": ["true"]
            },
            "canDeleteMessages": {
              "enum": ["true", "false"]
            }
          },
          "required": [ "isEnabled", "canDeleteMessages"]
        },
        {
          "additionalProperties": false,
          "properties": {
            "isEnabled": {
              "enum": ["false"]
            },
            "canDeleteMessages": {
              "enum": ["false"]
            }
          },
          "required": ["isEnabled"]
        }
      ]
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "target": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "*": {
              "type": "string",
              "enum": [ "*" ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "odsCode": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "odsCodes": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ccgCode": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "supplier": { "enum": [ "emis", "tpp", "vision", "microtest" ] }
          }
        }
      ]
    },
    "journeys": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "appointments": { "$ref": "#/definitions/appointmentsJourney" },
        "cdssAdvice": { "$ref": "#/definitions/cdssAdviceJourney" },
        "cdssAdmin": { "$ref": "#/definitions/cdssAdminJourney" },
        "medicalRecord": { "$ref": "#/definitions/medicalRecordJourney" },
        "prescriptions": { "$ref": "#/definitions/prescriptionsJourney" },
        "nominatedPharmacy": { "enum": [ "true", "false" ] },
        "notifications": { "enum": [ "true", "false" ] },
        "messaging": { "enum": [ "true", "false" ] },
        "supplier": { "enum": [ "Emis", "Tpp", "Vision", "Microtest" ] },
        "silverIntegrations": { "$ref": "#/definitions/silverIntegrations" },
        "userInfo": { "enum": ["true", "false"]  },
        "documents": { "enum": ["true", "false"]  },
        "im1Messaging": { "$ref": "#/definitions/im1MessagingJourney" }
      },
      "anyOf": [
        {
          "required": [ "appointments" ]
        },
        {
          "required": [ "cdssAdvice" ]
        },
        {
          "required": [ "cdssAdmin" ]
        },
        {
          "required": [ "medicalRecord" ]
        },
        {
          "required": [ "prescriptions" ]
        },
        {
          "required": [ "nominatedPharmacy" ]
        },
        {
          "required": [ "notifications" ]
        },
        {
          "required": [ "messaging" ]
        },
        {
          "required": [ "supplier" ]
        },
        {
          "required": [ "silverIntegrations" ]
        },
        {
          "required": [ "userInfo" ]
        },
        {
          "required": [ "documents" ]
        },
        {
          "required": [ "im1Messaging" ]
        }
      ]
    }
  },
  "required": [ "target", "journeys" ]
}