{
  "id": "https://nhsapp.service.nhs.uk/service-journey-rules.schema.json",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "description": "A single rule for the NHS App Journeys",
  "additionalProperties": false,
  "type": "object",
  "definitions": {
    "appointmentsJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "im1", "gpAtHand" ]
            }
          },
          "required": [ "provider" ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "informatica" ]
            },
            "informaticaUrl": { "type": "string" }
          },
          "required": [ "provider", "informaticaUrl" ]
        }
      ]
    },
    "cdssAdviceJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "none" ]
            }
          },
          "required": [ "provider" ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "eConsult", "stubs" ]
            },
            "serviceDefinition": { "type": "string" }
          },
          "required": [ "provider", "serviceDefinition" ]
        }
      ]
    },
    "cdssAdminJourney": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "none" ]
            }
          },
          "required": [ "provider" ]
        },
        {
          "additionalProperties": false,
          "properties": {
            "provider": {
              "enum": [ "eConsult", "stubs" ]
            },
            "serviceDefinition": { "type": "string" }
          },
          "required": [ "provider", "serviceDefinition" ]
        }
      ]
    },
    "medicalRecordJourney": {
      "properties": {
        "provider": {
          "enum": [ "im1", "gpAtHand" ]
        }
      },
      "required": [ "provider" ]
    },
    "prescriptionsJourney": {
      "properties": {
        "provider": {
          "enum": [ "im1", "gpAtHand" ]
        }
      },
      "required": [ "provider" ]
    }
  },
  "properties": {
    "$schema": { "type": "string" },
    "target": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "*": {
              "type": "string",
              "enum": [ "*" ]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "odsCode": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "odsCodes": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "ccgCode": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "supplier": { "enum": ["emis", "tpp", "vision", "microtest"] }
          }
        }
      ]
    },
    "journeys": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "appointments": { "$ref": "#/definitions/appointmentsJourney" },
        "cdssAdvice": { "$ref": "#/definitions/cdssAdviceJourney" },
        "cdssAdmin": { "$ref": "#/definitions/cdssAdminJourney" },
        "medicalRecord": { "$ref": "#/definitions/medicalRecordJourney" },
        "prescriptions": { "$ref": "#/definitions/prescriptionsJourney" },
        "nominatedPharmacy": { "enum": ["true", "false"]  },
        "notifications": { "enum": ["true", "false"]  },
        "messaging": { "enum": ["true", "false"]  },
        "supplier": { "enum": [ "Emis", "Tpp", "Vision", "Microtest" ] }
      },
      "anyOf": [
        {
          "required": [ "appointments" ]
        },
        {
          "required": [ "cdssAdvice" ]
        },
        {
          "required": [ "cdssAdmin" ]
        },
        {
          "required": [ "medicalRecord" ]
        },
        {
          "required": [ "prescriptions" ]
        },
        {
          "required": [ "nominatedPharmacy" ]
        },
        {
          "required": [ "notifications" ]
        },
        {
          "required": [ "messaging" ]
        },
        {
          "required": [ "supplier" ]
        }
      ]
    }
  },
  "required": ["target", "journeys"]
}