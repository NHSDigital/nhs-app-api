{
  "Logging": {
    "LogLevel": {
      "Default": "Information"
    },
    "Application": {
      "ErrorLevel": "Error",
      "StandardLevel": "Information",
      "CensorFilters": [
        {
          "Match": "userPatientLinkToken=[^&]*",
          "Replacement": "userPatientLinkToken=*****"
        },
        {
          "Match": "\\(NHSOnline\\.Backend\\.MessagesApi\\) with arguments \\(.+?\\)",
          "Replacement": "(NHSOnline.Backend.MessagesApi) with arguments (******)"
        }
      ]
    }
  },
  "ConfigurationSettings": {
    "DefaultHttpTimeoutSeconds": 10
  }
}