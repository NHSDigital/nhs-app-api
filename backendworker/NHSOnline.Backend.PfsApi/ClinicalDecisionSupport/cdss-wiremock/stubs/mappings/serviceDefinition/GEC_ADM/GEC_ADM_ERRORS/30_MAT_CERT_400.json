{
  "priority": 1,
  "request": {
    "method": "POST",
    "url": "/fhir/ServiceDefinition/GEC_ADM/$evaluate",
    "bodyPatterns" : [
      { "matchesJsonPath": "$.parameter[?(@.resource.questionnaire.reference === 'Questionnaire/GEC_ADM_AD_ISSUE')]"},
      { "matchesJsonPath" : "$.parameter[?(@.name === 'inputData')].resource.item[?(@.linkId == 'GEC_ADM_AD_ISSUE')].answer[?(@.valueCoding.code === 'GEC_ADM_AD_ISSUE_MATCERT')]"}
    ]
  },
  "response": {
    "status": 400,
    "headers": {
      "Content-Type": "application/json+fhir"
    }
  }
}
