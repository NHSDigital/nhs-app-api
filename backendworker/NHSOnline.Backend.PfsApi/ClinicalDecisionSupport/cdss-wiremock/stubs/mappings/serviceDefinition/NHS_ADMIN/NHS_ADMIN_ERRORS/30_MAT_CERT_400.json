{
  "priority": 2,
  "request": {
    "method": "POST",
    "url": "/fhir/ServiceDefinition/NHS_ADMIN/$evaluate",
    "bodyPatterns" : [
      { "matchesJsonPath": "$.parameter[?(@.resource.questionnaire.reference === 'Questionnaire/NHS_ADMIN_AD_ISSUE')]"},
      { "matchesJsonPath" : "$.parameter[?(@.name === 'inputData')].resource.item[?(@.linkId == 'NHS_ADMIN_AD_ISSUE')].answer[?(@.valueCoding.code === 'NHS_ADMIN_AD_ISSUE_MATCERT')]"}
    ]
  },
  "response": {
    "status": 400,
    "headers": {
      "Content-Type": "application/json+fhir"
    }
  }
}
