<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netcoreapp2.1</TargetFramework>
        <IsPackable>false</IsPackable>
        <CodeAnalysisRuleSet>..\TestCode.ruleset</CodeAnalysisRuleSet>
        <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
        <LangVersion>latest</LangVersion>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="AutoFixture" Version="4.10.0" />
        <PackageReference Include="AutoFixture.AutoMoq" Version="4.10.0" />
        <PackageReference Include="coverlet.msbuild" Version="2.3.1" />
        <PackageReference Include="FluentAssertions" Version="5.7.0" />
        <PackageReference Include="Microsoft.NET.Test.Sdk" Version="16.1.1" />
        <PackageReference Include="Moq" Version="4.11.0" />
        <PackageReference Include="MSTest.TestAdapter" Version="1.4.0" />
        <PackageReference Include="MSTest.TestFramework" Version="1.4.0" />
        <PackageReference Include="Microsoft.CodeAnalysis.FxCopAnalyzers" Version="2.6.0" />
        <PackageReference Include="ReportGenerator" Version="4.0.2" />
    </ItemGroup>

    <ItemGroup>
      <ProjectReference Include="..\NHSOnline.Backend.ServiceJourneyRulesApi\NHSOnline.Backend.ServiceJourneyRulesApi.csproj" />
      <ProjectReference Include="..\UnitTestHelper\UnitTestHelper.csproj" />
    </ItemGroup>

    <ItemGroup>
      <Content Include="TestData\Configurations\Journeys\defaults\all_defaults.yaml">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
      <Content Include="TestData\Configurations\Journeys\defaults\emis_supplier.yaml">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
      <Content Include="TestData\Configurations\Journeys\defaults\vision_supplier.yaml">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
      <Content Include="TestData\GpInfo\gpinfo.csv">
        <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      </Content>
      <EmbeddedResource Include="TestData\invalid_yaml.yaml" />
      <EmbeddedResource Include="TestData\Schemas\duplicate_file.json" />
      <EmbeddedResource Include="TestData\Schemas\invalid_schema.json" />
      <EmbeddedResource Include="TestData\Schemas\SubFolder\duplicate_file.json" />
      <EmbeddedResource Include="TestData\Schemas\valid_schema.json" />
      <None Remove="TestData\Schemas\invalid_schema.json" />
      <None Remove="TestData\Schemas\valid_schema.json" />
    </ItemGroup>

    <ItemGroup>
      <Folder Include="TestData\GpInfo" />
    </ItemGroup>

</Project>
