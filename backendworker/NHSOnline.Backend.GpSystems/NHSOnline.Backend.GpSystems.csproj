    </None>
    <None Update="Suppliers\Spine\PublicKeys\spine-dev.crt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Suppliers\Spine\PublicKeys\subca-dev.crt">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
    <None Update="Suppliers\Spine\PublicKeys\subca-prod.crt">
