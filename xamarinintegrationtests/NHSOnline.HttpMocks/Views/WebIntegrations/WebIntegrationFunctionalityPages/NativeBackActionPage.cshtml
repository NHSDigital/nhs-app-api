@model (string Title, Microsoft.AspNetCore.Http.HttpRequest Request)
<html>
  <head>
    <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
        <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css" integrity="sha384-9aIt2nRpC12Uk9gS9baDl411NQApFmC26EwAOH8WgZl5MYYxFfc+NcPb1dKGj7Sk" crossorigin="anonymous">
        <title>@Model.Title</title>
        <script type="text/javascript" src="https://pkb.securestubs.local.bitraft.io/nhsapp.js"></script>
        <script>        
              function setBackActionCall() {
                var action = document.getElementById("backActionFunctionTextarea");
                if (action.value !== '') {
                  var actionFunction = Function(action.value);
                  nhsapp.navigation.setBackAction(actionFunction);
                }
              }
        
              function clearBackActionCall() {
                document.getElementById("backActionFunctionTextarea").value = "";
                nhsapp.navigation.clearBackAction();
              }
        
              function callBackAction() {
                nhsapp.callbacks.back();
              }
            </script>
  </head>
<body>
<div class="jumbotron">
    <h1 class="display-4">@Model.Title</h1>
</div>
<div class="container">
  <label for="backActionFunctionTextarea">Enter function</label><br>
  <input type="text" id="backActionFunctionTextarea"><br><br>
  <button onclick="setBackActionCall()">Set Back Action</button><br>
  <button onclick="clearBackActionCall()">Clear Back Action</button><br>
  <button onclick="callBackAction()">Simulate back</button><br>
</div>
@await Html.PartialAsync("~/views/HttpRequestData.cshtml", Model.Request)
</body>
</html>
