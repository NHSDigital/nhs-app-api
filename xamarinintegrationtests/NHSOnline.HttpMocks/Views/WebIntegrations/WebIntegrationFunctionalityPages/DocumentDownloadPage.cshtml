@model NHSOnline.HttpMocks.Domain.DocumentDownload
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css" integrity="sha384-9aIt2nRpC12Uk9gS9baDl411NQApFmC26EwAOH8WgZl5MYYxFfc+NcPb1dKGj7Sk" crossorigin="anonymous">
    <title>@Model.Title</title>
    <script type="text/javascript" src="https://pkb.securestubs.local.bitraft.io/nhsapp.js"></script>
    <script>
        function setLogger() {
            if (!console) {
                console = {};
            }
            var old = console.log;
            var logger = document.getElementById('log');
            console.log = function (message) {
                if (typeof message == 'object') {
                    logger.innerHTML += (JSON && JSON.stringify ? JSON.stringify(message) : String(message)) + '<br />';
                } else {
                    logger.innerHTML += message + '<br />';
                }
            }
        }
    
        function downloadTestImageFile(base64) {
            let mimeType;
            let base64Data;
            let filename;
                  
            filename= "MyHandAndFootXrayPicture.bmp";
            mimeType = "image/bmp";
            base64Data = base64;
                
            nhsapp.storage.downloadFromBytes(base64Data, filename, mimeType);
        }
        
        function downloadTestPassKitFile(base64) {
          let mimeType;
          let base64Data;
          let filename;
                  
          filename= "TestAppleWalletPass.pkpass";
          mimeType = "application/vnd.apple.pkpass";
          base64Data = base64;
            
          nhsapp.storage.downloadFromBytes(base64Data, filename, mimeType);
        } 

        function downloadTestZipFile(base64) {
          let mimeType;
          let base64Data;
          let filename;
                  
          filename= "TestZipFile.zip";
          mimeType = "application/zip";
          base64Data = base64;
            
          nhsapp.storage.downloadFromBytes(base64Data, filename, mimeType);
        } 
        
        function downloadTestCorruptedFile(base64) {
          let mimeType;
          let base64Data;
          let filename;
                  
          filename= "MyWordDoc.docx";
          mimeType = "application/msword";
          base64Data = base64;
            
          nhsapp.storage.downloadFromBytes(base64Data, filename, mimeType);
        } 
    </script>
</head>
<body>
<div class="jumbotron">
    <h1 class="display-4">@Model.Title</h1>
</div>
<div class="container">
    <div id="log"></div>
    <ul class="list-group">
        <li class="list-group-item">
            <button id="test-image-download" onclick="downloadTestImageFile('@Model.ImageBase64String');">
                Download test image file
            </button>
        </li>
        <li class="list-group-item">
            <button id="test-pass-download" onclick="downloadTestPassKitFile('@Model.PkPassBase64String');">
                Download test pass kit file (ios only)
            </button>
        </li>
        <li class="list-group-item">
            <button id="test-pass-download-empty" onclick="downloadTestPassKitFile('@Model.CorruptedPassKitBase64');">
                Download corrupted test pass kit file (ios only)
            </button>
        </li>
        <li class="list-group-item">
            <button id="test-zip-download" onclick="downloadTestZipFile('@Model.ZipFileBase64String');">
                Download zip file
            </button>
        </li>
        <li class="list-group-item">
            <button id="test-corrupted-download" onclick="downloadTestCorruptedFile('@Model.CorruptedBase64String');">
                Download test corrupted file
            </button>
        </li>
        <li class="list-group-item">
            <a href="javascript:history.back()">Back</a>
        </li>
    </ul>
    <hr>
</div>
@await Html.PartialAsync("~/views/HttpRequestData.cshtml", Model.Request)
</body>
</html>