@model (string AuthHostName, string Redirect, string State, string PatientId)
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="stylesheet" href="https://service-manual.nhs.uk/css/main.css">
    <link rel="stylesheet" href="https://service-manual.nhs.uk/css/design-example-overrides.css">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css" integrity="sha384-9aIt2nRpC12Uk9gS9baDl411NQApFmC26EwAOH8WgZl5MYYxFfc+NcPb1dKGj7Sk" crossorigin="anonymous">
    <title>NHS Login Stubbed - Terms and Conditions</title>
</head>
<body>
    <div class="container">
        <h1 class="display-4">NHS Login - Terms and Conditions</h1>
        <div class="nhsuk-back-link">
            <a class="nhsuk-back-link__link" href="javascript: window.history.back();">
                <svg class="nhsuk-icon nhsuk-icon__chevron-left" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M8.5 12c0-.3.1-.5.3-.7l5-5c.4-.4 1-.4 1.4 0s.4 1 0 1.4L10.9 12l4.3 4.3c.4.4.4 1 0 1.4s-1 .4-1.4 0l-5-5c-.2-.2-.3-.4-.3-.7z"></path>
                </svg>
                Back
            </a>
        </div>
        <hr>
        <h2>Accept the terms and conditions?</h2>
        <form action="terms-and-conditions-declined" method="get" style="display: inline-block">
            <input value="@Model.Redirect" type="hidden" name="redirect_uri">
            <input value="@Model.Redirect" type="hidden" name="state">
            <input type="submit" value="Decline" class="btn btn-danger">
        </form>
        <form action="complete-login" method="get" id="AcceptTCsForm" style="display: inline-block">
            <input value="@Model.Redirect" type="hidden" name="redirect_uri">
            <input value="@Model.Redirect" type="hidden" name="state">
            <input value="@Model.PatientId" type="hidden" name="patientId">
            <input type="submit" value="Accept" class="btn btn-success">
        </form>
    </div>
</body>
</html>