@using NHSOnline.HttpMocks.CitizenId.Models
@model PatientUpliftModel
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.0/css/bootstrap.min.css" integrity="sha384-9aIt2nRpC12Uk9gS9baDl411NQApFmC26EwAOH8WgZl5MYYxFfc+NcPb1dKGj7Sk" crossorigin="anonymous">
    <title>NHS Login Stubbed - Uplift</title>
    <style>
        label.camera-button {
            display: inline-block;
            padding: 12px 24px;
            color: #fff;
            font-size: 20px;
            line-height: 32px;
            width: 100%;
            text-align: center;
            cursor: pointer;
            margin: 0;
            border: 2px solid #666;
            background-color: #007f3b;
        }
    </style>
    <script>
    function updateTextOnFileSelection() {
        document.getElementById('file-selected').innerText = "File selected";
    }
    
    function updateTextOnPhotoCapture() {
        document.getElementById('photo-captured').innerText = "Photo captured";
    }
    
    function UpliftSubmit(type) {
        document.getElementById('upliftSubmissionType').value = type;
       
        return true;
    }
    </script>
</head>
<body>
<div class="jumbotron">
    <h1 class="display-4">NHS Login - Uplift</h1>
</div>
<div class="container">
    <ul>
        <li>
            <a href="javascript: window.history.back();">Back</a>
        </li>
        <li>
            <a href="http://@Model.AuthHostName:8080/citizenid/Page/Internal.html">Internal Page</a>
        </li>
        <li>
            <a href="http://@Model.AuthHostName:8080/citizenid/Page/Internal.html" target="_blank">Internal Page (New Window)</a>
        </li>
        <li>
            <a href="http://@Model.AuthHostName:8080/citizenid/Page/NotFound.html">Not Found</a>
        </li>
        <li>
            <a href="http://@Model.AuthHostName:8080/citizenid/Page/InternalServerError.html">Internal Server Error</a>
        </li>
        <li>
            <a href="http://@Model.AuthHostName:8080/citizenid/Page/FailFast.html">Boom</a>
        </li>
        <li>
            <a href="http://stubs.local.bitraft.io:8080/nhsuk/covid">Covid</a>
        </li>
    </ul>
    <hr>
</div>
@await Html.PartialAsync("~/views/HttpRequestData.cshtml", Model.Request)
<div class="container">
    <p id="file-selected">No file selected</p>
    <label tabindex="0" for="file-upload" role="button" class="camera-button">
        Open photo library
        <input id="file-upload" type="file" name="image" accept="image/*"
               onchange="updateTextOnFileSelection()">
    </label>

    <p id="photo-captured">No photo captured</p>
    <label tabindex="0" for="photo-id-document" role="button" class="camera-button">
        Open Camera
        <input id="photo-id-document" type="file" name="image" accept="image/*" class="camera-input"
               capture="capture" onchange="updateTextOnPhotoCapture()">
    </label>
    <hr>
    <form action="complete-login" method="get" id="LoginForm">
        <input value="@Model.Redirect" type="hidden" name="redirect_uri">
        <input value="@Model.Scope" type="hidden" name="scope"/>
        <input value="@Model.State" type="hidden" name="state">
        <input value="@Model.PatientId" type="hidden" name="patientId">
        <input value="true" type="hidden" name="isUplift">
        <input type="hidden" name="upliftSubmissionType" id="upliftSubmissionType">
        <div class="form-group">
            <label for="PatientName">P5 Patient to Uplift</label>
            <input class="form-control" value="@Model.PatientName" readonly="readonly" name="patientName" id="PatientName"/>
        </div>
        <input type="submit" id="uplift" onclick="UpliftSubmit('@UpliftSubmissionType.Success')" value="UpliftSuccess" />
        <input type="submit" id="upliftTsAndCsDeclined" onclick="UpliftSubmit('@UpliftSubmissionType.TermsAndConditionsDeclined')" value="UpliftTermsAndConditionsDeclined" />
        <input type="submit" id="upliftError" onclick="UpliftSubmit('@UpliftSubmissionType.Error')" value="UpliftError" />
    </form>
</div>
</body>
</html>