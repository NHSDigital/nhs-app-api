<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="menu_default_text" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">sans-serif-medium</item>
      <item name="android:textColor">@color/defaultMenuTextColor</item>
      <item name="android:textSize">@dimen/menuBarItemFontSize</item>
    </style>

    <style name="error_header_default_text" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textColor">@color/black</item>
        <item name="android:textSize">@dimen/errorHeaderTextSize</item>
    </style>

    <style name="default_error_icon" parent="TextAppearance.AppCompat.Headline">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:background">@color/error</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">@dimen/errorTextSize</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="default_success_icon" parent="TextAppearance.AppCompat.Headline">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:background">@color/nhsBlue</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">@dimen/errorTextSize</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="default_warning_icon" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:background">@color/warning_title</item>
        <item name="android:textColor">@android:color/black</item>
        <item name="android:textSize">@dimen/errorTextSize</item>
        <item name="android:textAlignment">center</item>
    </style>

    <style name="default_warning_text" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">@dimen/_16ssp</item>
        <item name="android:padding">@dimen/_12sdp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:layout_marginTop">0dp</item>
        <item name="android:background">@android:color/white</item>
    </style>

    <style name="blue_button" parent="Base.TextAppearance.AppCompat.Button">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:background">@color/nhsBlue</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">@dimen/errorTextSize</item>
    </style>

    <style name="green_button" parent="Base.TextAppearance.AppCompat.Button">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:background">@color/darkGreen</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">@dimen/errorTextSize</item>
    </style>

    <style name="alert_dialogue_blue_button" parent="Base.TextAppearance.AppCompat.Button">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">@dimen/_12sdp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:layout_marginTop">0dp</item>
        <item name="android:background">@color/nhsBlue</item>
        <item name="android:shadowColor">@color/darkBlue</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">@dimen/errorTextSize</item>
    </style>

    <style name="alert_dialogue_green_button" parent="Base.TextAppearance.AppCompat.Button">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">@dimen/_12sdp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:layout_marginTop">0dp</item>
        <item name="android:background">@color/lightGreen</item>
        <item name="android:shadowColor">@color/darkGreen</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">@dimen/errorTextSize</item>
    </style>

    <style name="CustomSymptomsToolbar">
        <item name="navigationIcon">@drawable/back_arrow</item>
    </style>

    <style name="CustomBackArrowForBreadcrumb">
        <item name="navigationIcon">@drawable/back_arrow_breadcrumb</item>

    </style>

    <style name="biometric_breadcrumb_text" parent="TextAppearance.AppCompat">
        <item name="android:fontFamily">Frutiger W01 Helvetica, Arial, sans-serif</item>
        <item name="android:textColor">#330072</item>
    </style>
</resources>
