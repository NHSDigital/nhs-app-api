<?xml version="1.0" encoding="utf-8"?>
    <android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:id="@+id/biometricLayoutContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:paddingLeft="@dimen/_16sdp"
        android:paddingRight="@dimen/_16sdp"
        android:paddingTop="@dimen/_16sdp">

        <android.support.constraint.ConstraintLayout
            android:id="@+id/biometric_content_layout"
            android:layout_height="0dp"
            android:layout_width="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@+id/continue_button">

            <LinearLayout
                android:id="@+id/error_label_border"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="15.000sp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    style="@style/default_warning_icon"
                    android:layout_width="@dimen/_100ssp"
                    android:layout_height="@dimen/_35sdp"
                    android:paddingTop="@dimen/_6sdp"
                    android:textStyle="bold"
                    android:text="Important"/>

                <LinearLayout
                    android:id="@+id/default_warning_title_bar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="@dimen/_15sdp"
                    android:background="@drawable/warning_border"
                    android:orientation="horizontal" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/error_content"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/error_label_border"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/errorTextViewN"
                    style="@style/default_warning_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="@dimen/_40sdp"
                    android:text="@string/biometric_warning_message"
                    android:textColor="@color/black"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/info_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/error_content"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:orientation="vertical"
                android:layout_marginTop="24.000sp">

                <TextView
                    style="@style/menu_default_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/biometric_information_message1"
                    android:textSize="@dimen/_16ssp"
                    android:textStyle="bold" />

                <TextView
                    style="@style/menu_default_text"
                    android:id="@+id/link_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/biometric_information_message2"
                    android:linksClickable="true"
                    android:textSize="@dimen/_15ssp"
                    android:textColorLink="@color/colorPrimary"
                    android:layout_marginTop="@dimen/_5ssp"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/toggle_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@id/info_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:orientation="horizontal"
                android:visibility="gone"
                android:layout_marginTop="@dimen/_25ssp">

                <TextView
                    style="@style/menu_default_text"
                    android:textSize="@dimen/_16sdp"
                    android:textColor="@color/colorPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Fingerprint ID"/>

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1"/>

                <ToggleButton
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </android.support.constraint.ConstraintLayout>

        <Button
            style="@style/blue_button"
            android:id="@+id/continue_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/biometric_content_layout"
            android:textColor="@color/warning"
            android:layout_marginBottom="16dp"
            android:backgroundTint="@color/darkGreen"
            android:textAllCaps="false"
            android:enabled="false"
            android:visibility="gone"
            android:text="Continue">
        </Button>

    </android.support.constraint.ConstraintLayout>