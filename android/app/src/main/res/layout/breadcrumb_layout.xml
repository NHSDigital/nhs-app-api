<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_alignBottom="@id/breadcrumb_text_view"
    android:background="@color/breadcrumb_fill">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/breadcrumb"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:id="@+id/BackArrowBreadcrumb"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:src="@drawable/back_arrow_breadcrumb"
            android:layout_gravity="left" />

        <TextView
            android:id="@+id/breadcrumb_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/biometric_information_breadcrumb"
            android:textColor="@color/nhsBlue"
            android:textSize="@dimen/_12sdp" />


    </androidx.appcompat.widget.Toolbar>


</androidx.constraintlayout.widget.ConstraintLayout>
