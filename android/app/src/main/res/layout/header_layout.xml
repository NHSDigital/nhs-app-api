<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="@dimen/_40sdp"
    tools:background="@color/nhsBlue">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="4dp"
        android:gravity="center"
        android:orientation="vertical"
        tools:ignore="MissingConstraints">
        <ImageView
            android:id="@+id/homeLogoIcon"
            android:layout_width="wrap_content"
            android:adjustViewBounds="true"
            android:background="@drawable/icon_drawable_boarder_focusable"
            android:contentDescription="@string/nhsAppHome"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintBottom_toTopOf="@id/homeLogoIconText"
            android:nextFocusForward="@id/helpIcon"
            android:nextFocusDown="@id/webview"
            android:nextFocusLeft="@id/messages"
            android:nextFocusUp="@id/messages"
            android:paddingLeft="@dimen/_4sdp"
            android:paddingRight="@dimen/_4sdp"
            android:paddingTop="@dimen/_7sdp"
            android:paddingBottom="@dimen/_2sdp"
            android:layout_weight="1"
            android:src="@drawable/icon_drawable_home"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/homeLogoIconText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="1dp"
            android:importantForAccessibility="no"
            android:paddingBottom="@dimen/_2sdp"
            android:text="@string/home_header"
            android:textAlignment="center"
            android:textAppearance="@style/header_default_text"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHorizontal_bias="0.002"
            app:layout_constraintLeft_toLeftOf="@id/homeLogoIcon"
            app:layout_constraintRight_toRightOf="@id/homeLogoIcon"
            app:layout_constraintTop_toBottomOf="@id/homeLogoIcon" />

    </LinearLayout>

    <ImageView
        android:id="@+id/nhsLogoIcon"
        android:layout_width="0dp"
        android:layout_weight="1"
        android:layout_gravity="center_vertical"
        android:adjustViewBounds="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:background="@drawable/icon_drawable_boarder_focusable"
        android:layout_centerInParent="true"
        android:focusable="false"
        android:paddingTop="@dimen/_12sdp"
        android:paddingBottom="@dimen/_12sdp"
        android:paddingRight="@dimen/_4sdp"
        android:src="@drawable/icon_drawable_nhs_logo"
        android:layout_height="wrap_content"/>

    <ImageView
        android:id="@+id/helpIcon"
        android:layout_width="wrap_content"
        android:adjustViewBounds="true"
        android:background="@drawable/icon_drawable_boarder_focusable"
        android:contentDescription="@string/header_icon_help"
        android:focusable="true"
        android:focusableInTouchMode="false"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toLeftOf="@id/moreIcon"
        app:layout_constraintBottom_toTopOf="@id/helpIconText"
        android:nextFocusUp="@id/messages"
        android:nextFocusDown="@id/webview"
        android:nextFocusForward="@id/moreIcon"
        android:paddingLeft="@dimen/_6sdp"
        android:paddingRight="@dimen/_6sdp"
        android:paddingTop="@dimen/_7sdp"
        android:paddingBottom="@dimen/_2sdp"
        android:src="@drawable/icon_drawable_help"
        android:layout_height="0dp" />
    <TextView
        android:id="@+id/helpIconText"
        android:layout_height="wrap_content"
        android:layout_margin="1dp"
        app:layout_constraintTop_toBottomOf="@id/helpIcon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="@id/helpIcon"
        app:layout_constraintRight_toRightOf="@id/helpIcon"
        android:text="@string/header_icon_help_label"
        android:textAlignment="center"
        android:textAppearance="@style/header_default_text"
        android:layout_width="0dp"
        android:paddingBottom="@dimen/_2sdp"
        android:importantForAccessibility="no"/>

    <ImageView
        android:id="@+id/moreIcon"
        android:layout_width="47dp"
        android:layout_height="32dp"
        android:adjustViewBounds="true"
        android:background="@drawable/icon_drawable_boarder_focusable"
        android:contentDescription="@string/header_icon_settings"
        android:focusable="true"
        android:focusableInTouchMode="false"
        android:nextFocusUp="@id/messages"
        android:paddingLeft="@dimen/_6sdp"
        android:paddingTop="@dimen/_7sdp"
        android:paddingRight="@dimen/_14sdp"
        android:paddingBottom="@dimen/_2sdp"
        android:src="@drawable/icon_drawable_more_white"
        app:layout_constraintBottom_toBottomOf="@id/helpIcon"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/settingsIconText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="1dp"
        android:importantForAccessibility="no"
        android:paddingRight="@dimen/_6sdp"
        android:paddingBottom="@dimen/_2sdp"
        android:text="@string/header_icon_more_label"
        android:textAlignment="center"
        android:textAppearance="@style/header_default_text"
        app:layout_constraintHorizontal_bias="0.407"
        app:layout_constraintLeft_toRightOf="@id/helpIconText"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/moreIcon" />

</androidx.constraintlayout.widget.ConstraintLayout>
