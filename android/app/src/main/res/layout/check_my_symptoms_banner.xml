<?xml version="1.0" encoding="utf-8"?>
<android.support.constraint.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <FrameLayout
        android:id="@+id/viewSwitcher"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintVertical_bias="1.0">

        <WebView
            android:id="@+id/symptomsWebview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:baselineAligned="false"
            android:visibility="visible" />

        <ScrollView
            android:id="@+id/errorViewLayoutU"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background"
            android:padding="@dimen/_12sdp"
            android:visibility="gone">

            <include layout="@layout/error_layout" />
        </ScrollView>
    </FrameLayout>

    <android.support.v7.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/CustomSymptomsToolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/colorPrimary"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/header_text_view"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/_6sdp"
            android:text="@string/symptoms_header"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/_18sdp" />
    </android.support.v7.widget.Toolbar>

    <LinearLayout
        android:id="@+id/progressBarLayoutU"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/progress_spinner_background"
        android:gravity="center">

        <ProgressBar
            android:id="@+id/progressBarU"
            style="?android:attr/progressBarStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:indeterminateTint="@color/progressbar_color"
            android:indeterminateTintMode="src_in" />
    </LinearLayout>
</android.support.constraint.ConstraintLayout>
