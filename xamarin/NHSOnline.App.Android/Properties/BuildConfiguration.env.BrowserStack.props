<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <NhsAppPackageName>com.nhs.online.nhsonline.browserstack</NhsAppPackageName>
    <NhsAppLabel>NHS App - BrowserStack</NhsAppLabel>
    <NhsAppEnableStubs>true</NhsAppEnableStubs>
    <GoogleServicesFile>Configuration/Develop/google-services.json</GoogleServicesFile>
    <DefineConstants>$(DefineConstants);DEBUG_WEBVIEW;</DefineConstants>
  </PropertyGroup>
</Project>
