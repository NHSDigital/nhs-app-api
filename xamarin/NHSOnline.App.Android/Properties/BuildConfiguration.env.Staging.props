<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <NhsAppScheme>nhsapp</NhsAppScheme>
    <NhsAppAuthRedirectPath>/auth-return</NhsAppAuthRedirectPath>
    <NhsAppBaseHost>www-staging.dev.nonlive.nhsapp.service.nhs.uk</NhsAppBaseHost>
    <NhsAppBaseScheme>https</NhsAppBaseScheme>
    <ErsUrl>pat.sa.refer.nhs.uk</ErsUrl>
    <ErsUrlPath>/nhslogin</ErsUrlPath>
    <ErsUrlScheme>https</ErsUrlScheme>
    <NhsAppPackageName>com.nhs.online.nhsonline.staging</NhsAppPackageName>
    <NhsAppLabel>NHS App - Staging</NhsAppLabel>
    <GoogleServicesFile>Configuration/Staging/google-services.json</GoogleServicesFile>
  </PropertyGroup>
</Project>
