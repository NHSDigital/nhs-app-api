<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <NhsAppBaseHost>web.local.bitraft.io</NhsAppBaseHost>
    <NhsAppBaseScheme>http</NhsAppBaseScheme>
    <ErsUrl>pat.rc.refer.nhs.uk</ErsUrl>
    <NhsAppPackageName>com.nhs.online.nhsonline.local</NhsAppPackageName>
    <NhsAppLabel>NHS App - Local</NhsAppLabel>
    <NhsAppEnableStubs>true</NhsAppEnableStubs>
    <GoogleServicesFile>Configuration/Develop/google-services.json</GoogleServicesFile>
  </PropertyGroup>
</Project>
