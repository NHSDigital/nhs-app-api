<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NHSOnline.App.Controls.Heading1"
             x:Name="Root" Margin="0, 20, 20, 0">
    
    <View.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="NhsUkColours.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="Label">
                <Setter Property="FontSize" Value="Title" />
                <Setter Property="FontFamily" Value="Frutiger-Bold" />
                <Setter Property="TextColor" Value="{Binding TextColour, Source={x:Reference Name=Root}}" />
            </Style>
        </ResourceDictionary>
    </View.Resources>
    
    
    <StackLayout>
        <Label Text="{Binding Text, Source={x:Reference Name=Root}}" />
    </StackLayout>
</ContentView>