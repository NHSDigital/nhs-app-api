<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:icons="clr-namespace:NHSOnline.App.Controls.Icons;assembly=NHSOnline.App.Controls"
             xmlns:controls="clr-namespace:NHSOnline.App.Controls;assembly=NHSOnline.App.Controls"
             x:Class="NHSOnline.App.Controls.SlimCloseAndLogoNavigationHeader"
             x:Name="Root">

    <View.Resources>
        <ResourceDictionary>
            
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="NhsUkColours.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <Style TargetType="StackLayout">
                <Setter Property="HorizontalOptions" Value="FillAndExpand" />
                <Setter Property="BackgroundColor" Value="{StaticResource NhsUkBlue}" />
            </Style>
            
            <Style TargetType="icons:IconClose">
                <Setter Property="HorizontalOptions" Value="Start" />
                <Setter Property="VerticalOptions" Value="Center" />
                <Setter Property="Margin" Value="10,0,0,0" />
                <Setter Property="HeightRequest" Value="30" />
                <Setter Property="WidthRequest" Value="30" />
            </Style>
            
            <Style TargetType="controls:MediumLabel">
                <Setter Property="VerticalOptions" Value="CenterAndExpand" />
                <Setter Property="TextColor" Value="{StaticResource NhsUkWhite}" />
            </Style>
            
            <Style TargetType="controls:NhsLogo">
                <Setter Property="HeightRequest" Value="25" />
                <Setter Property="WidthRequest" Value="60" />
                <Setter Property="Padding" Value="0,0,10,10" />
            </Style>
            
        </ResourceDictionary>
    </View.Resources>

    <StackLayout AutomationId="NHS App Slim Close Navigation Header"
                 Orientation="Vertical">
        <StackLayout Orientation="Horizontal"
                     Margin="0,0,0,5">
            
            <icons:IconClose AutomationProperties.IsInAccessibleTree="True">
                
                <icons:IconClose.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CloseCommand, Source={x:Reference Name=Root}}"  />
                </icons:IconClose.GestureRecognizers>
                
            </icons:IconClose>
            
            <controls:MediumLabel Text="Close" />
        </StackLayout>
        
        <StackLayout Orientation="Horizontal"
                     Margin="15,0,0,10">
            
            <controls:NhsLogo />
            
            <controls:MediumLabel Text="NHS App"
                                  Margin="0,0,0,10" />
            
        </StackLayout>
    </StackLayout>
</ContentView>
