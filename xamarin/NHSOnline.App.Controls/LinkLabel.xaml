<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NHSOnline.App.Controls.LinkLabel"
             x:Name="Root">
    <View.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="NhsUkColours.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource NhsUkPrimaryLinkBlue}" />
                <Setter Property="TextDecorations" Value="Underline" />
                <Setter Property="FontSize" Value="15" />
            </Style>
        </ResourceDictionary>
    </View.Resources>
    
    <Label AutomationProperties.IsInAccessibleTree="true" Text="{Binding Text, Source={x:Reference Name=Root}}">
        <Label.GestureRecognizers>
            <TapGestureRecognizer Command="{Binding Command, Source={x:Reference Name=Root}}"  />
        </Label.GestureRecognizers>
    </Label>
</ContentView>