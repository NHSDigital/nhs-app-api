<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:effects="clr-namespace:NHSOnline.App.Controls.Effects;assembly=NHSOnline.App.Controls"
             xmlns:controls="clr-namespace:NHSOnline.App.Controls;assembly=NHSOnline.App.Controls"
             x:Class="NHSOnline.App.Controls.Navigation.FullNavigationFooterItemWide"
             x:Name="Root">
 
    <View.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Styles/NhsUkColours.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <Style TargetType="controls:AccessibilityLayout" Class="Outer">
                <Setter Property="WidthRequest" Value="110" />
            </Style>
            
            <Style TargetType="StackLayout">
                <Setter Property="Orientation" Value="Horizontal" />
                <Setter Property="HorizontalOptions" Value="CenterAndExpand" />
                <Setter Property="BackgroundColor" Value="{StaticResource NhsUkWhite}" />
                <Setter Property="HeightRequest" Value="50" />
            </Style>
            
            <Style TargetType="Label">
                <Setter Property="FontSize" Value="10" />
                <Setter Property="LineBreakMode" Value="WordWrap" />
                <Setter Property="VerticalTextAlignment" Value="Center" />
                <Setter Property="HorizontalOptions" Value="Center" />
                <Setter Property="VerticalOptions" Value="Center" />
                <Setter Property="effects:FixedFontSizeEffect.HasFixedFontSize" Value="True" /> 
            </Style>
        </ResourceDictionary>
    </View.Resources>
    
    <ContentView.Content>
        <controls:AccessibilityLayout StyleClass="Outer" 
                                      AutomationId="{Binding Text, Source={x:Reference Name=Root}}"
                                      effects:AccessibilityEffect.ControlType="Button" 
                                      effects:AccessibilityEffect.Selected="{Binding IsSelected, Source={x:Reference Name=Root}}"
                                      IsSelected="{Binding IsSelected, Source={x:Reference Name=Root}}"
                                      AutomationProperties.Name="{Binding Text, Source={x:Reference Name=Root}}"
                                      x:Name="IconButtonOuter">
            
            <VisualStateManager.VisualStateGroups>
                <VisualStateGroup>
                    <VisualState x:Name="KeyboardUnfocused" />
                    <VisualState x:Name="KeyboardFocused">
                        <VisualState.Setters>
                            <Setter TargetName="ItemIcon" Property="ContentView.Content" Value="{Binding FocusedIcon, Source={x:Reference Name=Root}}"/>
                            <Setter TargetName="ItemLabel" Property="Label.TextColor" Value="{StaticResource NhsUkPrimaryText}"/>
                            <Setter TargetName="IconButtonOuter" Property="controls:AccessibilityLayout.BackgroundColor" Value="{StaticResource NhsUkYellow}"/>
                            <Setter TargetName="IconButtonInner" Property="StackLayout.BackgroundColor" Value="{StaticResource NhsUkYellow}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="KeyboardSelectedUnfocused">
                        <VisualState.Setters>
                            <Setter TargetName="ItemIcon" Property="ContentView.Content" Value="{Binding SelectedIcon, Source={x:Reference Name=Root}}" />
                            <Setter TargetName="ItemLabel" Property="Label.TextColor" Value="{StaticResource NhsUkBlue}"/>
                            <Setter TargetName="IconButtonOuter" Property="controls:AccessibilityLayout.BackgroundColor" Value="{StaticResource NhsUkWhite}"/>
                            <Setter TargetName="IconButtonInner" Property="StackLayout.BackgroundColor" Value="{StaticResource NhsUkWhite}"/>
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="KeyboardSelectedFocused">
                        <VisualState.Setters>
                            <Setter TargetName="ItemIcon" Property="ContentView.Content" Value="{Binding SelectedIcon, Source={x:Reference Name=Root}}" />
                            <Setter TargetName="ItemLabel" Property="Label.TextColor" Value="{StaticResource NhsUkBlue}" />
                            <Setter TargetName="IconButtonOuter" Property="controls:AccessibilityLayout.BackgroundColor" Value="{StaticResource NhsUkYellow}"/>
                            <Setter TargetName="IconButtonInner" Property="StackLayout.BackgroundColor" Value="{StaticResource NhsUkYellow}"/>
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateManager.VisualStateGroups>
            
            <StackLayout AutomationId="{Binding Text, Source={x:Reference Name=Root}}"
                         x:Name="IconButtonInner">
                
                <ContentView x:Name="ItemIcon" IsTabStop="False" Content="{Binding DefaultIcon, Source={x:Reference Name=Root}}" />
                
                <Label x:Name="ItemLabel"
                       Text="{Binding Text, Source={x:Reference Name=Root}}"
                       AutomationProperties.IsInAccessibleTree="False"
                       IsTabStop="False"/>
            </StackLayout>
            
            <StackLayout.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding IconCommand, Source={x:Reference Name=Root}}" />
            </StackLayout.GestureRecognizers>
        </controls:AccessibilityLayout>
    </ContentView.Content>
</ContentView>
