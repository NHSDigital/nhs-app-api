<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NHSOnline.App.Controls.ListItem"
             x:Name="Root">
    <View.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="NhsUkColours.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="Label" Class="Bullet">
                <Setter Property="TextColor" Value="{StaticResource NhsUkPrimaryText}" />
                <Setter Property="FontSize" Value="15" />
            </Style>
            <Style TargetType="StackLayout" Class="ListItem">
                <Setter Property="Margin" Value="10, 2, 10, 2" />
            </Style>
        </ResourceDictionary>
    </View.Resources>
    
    <ContentView.Content>
        <StackLayout StyleClass="ListItem"
                     Orientation="Horizontal">
            <Label StyleClass="Bullet" AutomationProperties.IsInAccessibleTree="true" Text="&#x2022; " TextColor="{StaticResource NhsUkPrimaryText}" />
            <ContentView Content="{Binding ListItemContent, Source={x:Reference Name=Root}}" />
        </StackLayout>
    </ContentView.Content>
</ContentView>