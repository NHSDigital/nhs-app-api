<?xml version="1.0" encoding="utf-8"?>

<ContentView xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="NHSOnline.App.Controls.ResponsiveListItem"
             x:Name="Root">
    
    <VisualStateManager.VisualStateGroups>
        <VisualStateGroup x:Name="ResponsiveStates">
            <VisualState x:Name="Narrow"/>
            <VisualState x:Name="Wide">
                <VisualState.Setters>
                    <Setter TargetName="LabelText" Property="Style" Value="{ StaticResource ListItemTextWide}" />
                    <Setter TargetName="Bullet" Property="Style" Value="{ StaticResource ListItemTextWide}" />
                </VisualState.Setters>
            </VisualState>
        </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>
    
    <View.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Styles/NhsUkColours.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{StaticResource NhsUkPrimaryText}" />
                <Setter Property="FontSize" Value="16" />
                <Setter Property="FontFamily" Value="Frutiger" />
                <Setter Property="LineHeight" Value="1.2" />
            </Style>
            <Style x:Key="ListItemTextWide" TargetType="Label">
                <Setter Property="FontSize" Value="24" />
            </Style>
            <Style TargetType="StackLayout">
                <Setter Property="Margin" Value="10, 0, 10, 5" />
            </Style>
        </ResourceDictionary>
    </View.Resources>
    
    <ContentView.Content>
        <StackLayout StyleClass="ListItem"
                     Orientation="Horizontal">
            <Label x:Name="Bullet" Text="&#x2022; " TextColor="{StaticResource NhsUkPrimaryText}" />
            <Label x:Name="LabelText" Text="{Binding Text, Source={x:Reference Name=Root}}" />
        </StackLayout>
    </ContentView.Content>
</ContentView>