<?xml version="1.0" encoding="utf-8"?>
<pages:NhsAppPreHomeHeaderPage xmlns="http://xamarin.com/schemas/2014/forms"
                               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                               xmlns:d="http://xamarin.com/schemas/2014/forms/design"
                               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                               xmlns:webViews="clr-namespace:NHSOnline.App.Controls.WebViews;assembly=NHSOnline.App.Controls"
                               xmlns:pages="clr-namespace:NHSOnline.App.Navigation.Pages;assembly=NHSOnline.App"
                               xmlns:views="clr-namespace:NHSOnline.App.Areas.PreHome.Views;assembly=NHSOnline.App"
                               xmlns:controls="clr-namespace:NHSOnline.App.Controls;assembly=NHSOnline.App.Controls"
                               mc:Ignorable="d"
                               x:Class="NHSOnline.App.Areas.PreHome.Views.NhsAppPreHomeScreenWebPage">
    
    <AbsoluteLayout>
        <controls:Spinner AbsoluteLayout.LayoutFlags="All"
                          AbsoluteLayout.LayoutBounds="0, 0, 1, 1"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          WidthRequest="75"
                          HeightRequest="75"
                          x:Name="Spinner" />
   
        <webViews:NhsAppPreHomeScreenWebview AbsoluteLayout.LayoutFlags="All"
                                             AbsoluteLayout.LayoutBounds="0, 0, 1, 1"
                                             x:Name="WebView" VerticalOptions = "FillAndExpand" 
                                             RequestPnsTokenCommand="{Binding RequestPnsTokenCommand, Source={RelativeSource AncestorType={x:Type views:NhsAppPreHomeScreenWebPage}}}"
                                             GetNotificationsStatusCommand="{Binding GetNotificationsStatusCommand, Source={RelativeSource AncestorType={x:Type views:NhsAppPreHomeScreenWebPage}}}"
                                             GoToLoggedInHomeScreenCommand="{Binding GoToLoggedInHomeCommand, Source={RelativeSource AncestorType={x:Type views:NhsAppPreHomeScreenWebPage}}}"
                                             Navigating="WebViewNavigating"
                                             Navigated="WebOnEndNavigating" />
    </AbsoluteLayout>
</pages:NhsAppPreHomeHeaderPage>