<?xml version="1.0" encoding="utf-8" ?>
<pages:NhsAppCloseSlimHeaderPage xmlns="http://xamarin.com/schemas/2014/forms"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                    xmlns:d="http://xamarin.com/schemas/2014/forms/design"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:webViews="clr-namespace:NHSOnline.App.Controls.WebViews;assembly=NHSOnline.App.Controls"
                    xmlns:pages="clr-namespace:NHSOnline.App.Navigation.Pages;assembly=NHSOnline.App"
                    xmlns:elements="clr-namespace:NHSOnline.App.Controls.Elements;assembly=NHSOnline.App.Controls"
                    xmlns:effects="clr-namespace:NHSOnline.App.Controls.Effects;assembly=NHSOnline.App.Controls"
                    mc:Ignorable="d"
                    x:Class="NHSOnline.App.Areas.LoggedOut.Views.NhsLoginPage"
                    x:Name="Page">
    <AbsoluteLayout>
        <elements:Spinner AbsoluteLayout.LayoutFlags="All"
                          AbsoluteLayout.LayoutBounds="0, 0, 1, 1"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          Margin="0,0,0,50"
                          x:Name="Spinner" >
            <elements:Spinner.Effects>
                <effects:SafeAreaPaddingBottom />
            </elements:Spinner.Effects>
        </elements:Spinner>       
        
        <webViews:NhsLoginWebView AbsoluteLayout.LayoutFlags="All"
                                  AbsoluteLayout.LayoutBounds="0, 0, 1, 1"
                                  x:Name="WebView" 
                                  VerticalOptions = "FillAndExpand"
                                  Navigating="WebViewNavigating"
                                  Navigated="WebOnEndNavigating" />
    </AbsoluteLayout>
</pages:NhsAppCloseSlimHeaderPage>
