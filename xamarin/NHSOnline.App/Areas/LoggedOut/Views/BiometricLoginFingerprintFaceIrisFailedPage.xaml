<?xml version="1.0" encoding="utf-8"?>

<pages:NhsAppCloseAndLogoHeaderPage xmlns="http://xamarin.com/schemas/2014/forms"
                                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                                    xmlns:pages="clr-namespace:NHSOnline.App.Navigation.Pages;assembly=NHSOnline.App"
                                    xmlns:deprecated="clr-namespace:NHSOnline.App.Controls.Elements.Deprecated;assembly=NHSOnline.App.Controls"
                                    x:Class="NHSOnline.App.Areas.LoggedOut.Views.BiometricLoginFingerprintFailedPage"
                                    x:Name="Page">
    <ScrollView BackgroundColor="{StaticResource NhsUkPageBackgroundGrey}">
        <StackLayout Padding="20,0,20,0">
            <deprecated:Heading1 Text="We cannot find your fingerprint, face or iris" x:Name="Heading" />
            
            <deprecated:Paragraph Text="Check that you have added a fingerprint, face or iris in your device's security settings."
                                Padding="0,10,0,0" />
            
            <deprecated:LinkLabel Text="Back to login"
                                Command="{Binding BackHomeCommand, Source={x:Reference Name=Page}}"
                                Padding="0,10,0,0" />
        </StackLayout>
    </ScrollView>
</pages:NhsAppCloseAndLogoHeaderPage>