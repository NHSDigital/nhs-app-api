<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:d="http://xamarin.com/schemas/2014/forms/design"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ios="clr-namespace:Xamarin.Forms.PlatformConfiguration.iOSSpecific;assembly=Xamarin.Forms.Core" 
             ios:Page.UseSafeArea="False"
             xmlns:controls="clr-namespace:NHSOnline.App.Controls;assembly=NHSOnline.App.Controls"
             xmlns:icons="clr-namespace:NHSOnline.App.Controls.Icons;assembly=NHSOnline.App.Controls"
             mc:Ignorable="d"
             x:Class="NHSOnline.App.Areas.LoggedOut.Views.LoggedOutHomeScreenPage"
             x:Name="Root">
    
    <controls:GradientBackground BackgroundColor="{ StaticResource HomeBlueInnerGradient }"
                                 InnerColour="{ StaticResource HomeBlueInnerGradient }"
                                 OuterColour="{ StaticResource HomeBlueOuterGradient }"
                                 Radius="Max" >
        <ContentView.Effects>
            <controls:SafeAreaPaddingTop />
        </ContentView.Effects>

        <StackLayout BackgroundColor="Transparent">
        <AbsoluteLayout VerticalOptions="FillAndExpand" Margin="0,0,0,0">
            <StackLayout AbsoluteLayout.LayoutBounds="0, 0, 1, 1"
                         AbsoluteLayout.LayoutFlags="All">
                <StackLayout HorizontalOptions="FillAndExpand"
                             BackgroundColor="{ StaticResource NhsUkYellow}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="9*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Label Padding="20,10,10,10" Grid.Column="0">
                            <Label.FormattedText>
                                <FormattedString>
                                    <Span Text="Coronavirus (COVID-19)&#10;" 
                                          FontAttributes="Bold"
                                          FontSize="12" LineHeight="1" />
                                    <Span Text="Get information about coronavirus on NHS.UK"
                                          FontSize="12" LineHeight="1.5" />
                                </FormattedString>
                            </Label.FormattedText>
                        </Label>
                        <icons:IconArrowRight Grid.Column="1" 
                            HeightRequest="20"
                            VerticalOptions="Center"
                            HorizontalOptions="Center" />
                    </Grid>
                    <StackLayout.GestureRecognizers>
                        <TapGestureRecognizer 
                            Command="{Binding NhsUkCovidConditionsServiceCommand, Source={x:Reference Name=Root}}" />
                    </StackLayout.GestureRecognizers>
                </StackLayout>
                <StackLayout StyleClass="LogoPanel"
                             VerticalOptions="FillAndExpand">
                    
                    <StackLayout HorizontalOptions="End"
                                 Padding="0,10,10,0">
                        <icons:IconHelp HeightRequest="30"
                                        Padding="0,0,10,0"
                                        AutomationProperties.IsInAccessibleTree="true">
                            <icons:IconHelp.GestureRecognizers>
                                <TapGestureRecognizer 
                                    Command="{Binding NhsUkLoginHelpServiceCommand, Source={x:Reference Name=Root}}" />
                            </icons:IconHelp.GestureRecognizers>
                        </icons:IconHelp>
                        <Label Text="Help"
                               TextColor="{ StaticResource NhsUkWhite }"
                               FontSize="14" />
                    </StackLayout>

                    <BoxView VerticalOptions="FillAndExpand" />

                    <controls:NhsLogo HorizontalOptions="Center"
                                      HeightRequest="48" />

                    <BoxView VerticalOptions="FillAndExpand" />
                </StackLayout>

            </StackLayout>
        </AbsoluteLayout>

        <StackLayout StyleClass="LoginPanel">
            <Label Text="Access your NHS services"
                   StyleClass="Heading2"
                   HorizontalOptions="Center"
                   FontAttributes="Bold"
                   TextColor="{ StaticResource NhsUkWhite }" />
            <controls:ButtonWithImage Text="Continue with NHS login"
                                      ButtonColour = "{StaticResource NhsUkWhite}"
                                      TextColour = "{ StaticResource NhsUkBlue }"
                                      ColourGradient="{ StaticResource NhsUkDarkBlue }"
                                      Command="{Binding LoginCommand, Source={x:Reference Name=Root} }"
                                      ImageSource="NHSLoginLogo"
                                      HeightRequest="40" />
            <Label Text="Get advice without logging in"
                   HorizontalOptions="Center"
                   TextColor="{ StaticResource NhsUkWhite }"
                   TextDecorations="Underline"
                   FontAttributes="Bold"
                   FontFamily="Frutiger"
                   Margin="0,5,0,0"
                   FontSize="15" />
            <Label Text="Version 2.Xamarin"
                   HorizontalOptions="Center"
                   FontAttributes="Bold"
                   FontFamily="Frutiger"
                   TextColor="{ StaticResource NhsUkWhite }"
                   FontSize="12"
                   Margin="0,5,0,0" />
        </StackLayout>
    </StackLayout>
    </controls:GradientBackground>  


    <ContentPage.Resources>
        <ResourceDictionary>
            <Style TargetType="StackLayout" Class="LoginPanel">
                <Setter Property="Margin" Value="0, 0, 0, 40" />
                <Setter Property="Padding" Value="16,0,16,0" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

</ContentPage>
