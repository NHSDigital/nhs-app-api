<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:d="http://xamarin.com/schemas/2014/forms/design"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ios="clr-namespace:Xamarin.Forms.PlatformConfiguration.iOSSpecific;assembly=Xamarin.Forms.Core" 
             ios:Page.UseSafeArea="False"
             xmlns:controls="clr-namespace:NHSOnline.App.Controls;assembly=NHSOnline.App.Controls"
             xmlns:icons="clr-namespace:NHSOnline.App.Controls.Icons;assembly=NHSOnline.App.Controls"
             mc:Ignorable="d"
             x:Class="NHSOnline.App.Areas.LoggedOut.Views.LoggedOutHomeScreenPage"
             x:Name="Root">
    
    <controls:GradientBackground BackgroundColor="{ StaticResource HomeBlueInnerGradient }"
                                 InnerColour="{ StaticResource HomeBlueInnerGradient }"
                                 OuterColour="{ StaticResource HomeBlueOuterGradient }"
                                 Radius="Max" >
        <ContentView.Effects>
            <controls:SafeAreaPaddingTop />
        </ContentView.Effects>
        
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="10" />
                <ColumnDefinition />
                <ColumnDefinition Width="10" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition />
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="25"/>
            </Grid.RowDefinitions>
            
            <BoxView HorizontalOptions="FillAndExpand"
                     BackgroundColor="{ StaticResource NhsUkYellow}"
                     Grid.ColumnSpan="3" >
                <BoxView.GestureRecognizers>
                    <TapGestureRecognizer 
                        Command="{Binding NhsUkCovidConditionsServiceCommand, Source={x:Reference Name=Root}}" />
                </BoxView.GestureRecognizers>
            </BoxView>
                
            <Label Grid.Column="1"
                   Grid.Row="0" 
                   Padding="0,10,0,10"
                   AutomationProperties.IsInAccessibleTree="True">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Coronavirus (COVID-19)&#10;" 
                                  FontFamily="Frutiger-Bold"
                                  FontSize="Small" LineHeight="1" />
                            <Span Text="Get information about coronavirus on NHS.UK"
                                  FontFamily="Frutiger"
                                  FontSize="Small" LineHeight="1.5" />
                        </FormattedString>
                    </Label.FormattedText>
                    <Label.GestureRecognizers>
                        <TapGestureRecognizer 
                            Command="{Binding NhsUkCovidConditionsServiceCommand, Source={x:Reference Name=Root}}" />
                    </Label.GestureRecognizers>
            </Label>
            
            <icons:IconArrowRight Grid.Row="0" 
                                  Grid.Column="1" 
                                  HeightRequest="20"
                                  VerticalOptions="Center"
                                  HorizontalOptions="End" >
                <icons:IconArrowRight.GestureRecognizers>
                    <TapGestureRecognizer 
                        Command="{Binding NhsUkCovidConditionsServiceCommand, Source={x:Reference Name=Root}}" />
                </icons:IconArrowRight.GestureRecognizers>
            </icons:IconArrowRight>
            
            <StackLayout Grid.Row="1" 
                         Grid.Column="1" 
                         HorizontalOptions="End"
                         VerticalOptions="Start">
                
                <icons:IconHelp
                    HeightRequest="37"
                    AutomationProperties.IsInAccessibleTree="true"
                    AutomationProperties.HelpText="NHS App help icon">
                    <icons:IconHelp.GestureRecognizers>
                        <TapGestureRecognizer 
                            Command="{Binding NhsUkLoginHelpServiceCommand, Source={x:Reference Name=Root}}" />
                    </icons:IconHelp.GestureRecognizers>
                </icons:IconHelp>
                
                <Label Text="Help"
                       TextColor="{ StaticResource NhsUkWhite }"
                       FontSize="Small"
                       HorizontalOptions="Center"
                       AutomationProperties.IsInAccessibleTree="false"/>
            </StackLayout>
            
            <controls:NhsLogo Grid.Row="1" 
                              Grid.Column="1"
                              HorizontalOptions="Center"
                              VerticalOptions="Center"
                              HeightRequest="48" />
            
            <Label Grid.Row="2" 
                   Grid.Column="1"
                   Text="Access your NHS services"
                   StyleClass="Heading2"
                   HorizontalOptions="Center"
                   TextColor="{ StaticResource NhsUkWhite }" 
                   Padding="0,10,0,0"/>

            <controls:NhsLoginButton Grid.Row="3" Grid.Column="1" Text="Continue with NHS login"
                                      ButtonColour = "{StaticResource NhsUkWhite}"
                                      PressedButtonColour="{StaticResource NhsUkSecondaryGrey4}"
                                      TextColour = "{ StaticResource NhsUkBlue }"
                                      Command="{Binding LoginCommand, Source={x:Reference Name=Root} }"
                                      Padding="0,10,0,10"/>
            
            <Label Grid.Row="4" 
                   Grid.Column="1"
                   Text="Get advice without logging in"
                   HorizontalOptions="Center"
                   TextColor="{ StaticResource NhsUkWhite }"
                   TextDecorations="Underline"
                   FontAttributes="Bold"
                   FontFamily="Frutiger"
                   Margin="0,10,0,10"
                   FontSize="Medium" />
            
            <Label Grid.Row="5" 
                   Grid.Column="1" 
                   Text="Version 2.Xamarin"
                   HorizontalOptions="Center"
                   FontAttributes="Bold"
                   FontFamily="Frutiger"
                   TextColor="{ StaticResource NhsUkWhite }"
                   FontSize="Small"
                   Margin="0,10,0,10" />
        </Grid>
    </controls:GradientBackground>

</ContentPage>
