<?xml version="1.0" encoding="utf-8"?>
<pages:NhsAppCloseAndLogoHeaderPage xmlns="http://xamarin.com/schemas/2014/forms"
                                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                                    xmlns:pages="clr-namespace:NHSOnline.App.Navigation.Pages;assembly=NHSOnline.App"
                                    xmlns:elements="clr-namespace:NHSOnline.App.Controls.Elements;assembly=NHSOnline.App.Controls"
                                    xmlns:panels="clr-namespace:NHSOnline.App.Controls.Panels;assembly=NHSOnline.App.Controls"
                                    x:Class="NHSOnline.App.Areas.LoggedOut.Views.BiometricLoginFingerprintLockedOutPage"
                                    x:Name="Page">
    <ScrollView BackgroundColor="{StaticResource NhsUkPageBackgroundGrey}">
        <StackLayout>
            <elements:ResponsiveHeading1 x:Name="Heading" 
                                         Text="Turn on fingerprint, face or iris again" />
           
            <panels:NhsResponsiveContentPanel>
                <StackLayout>
                    <elements:ResponsiveParagraph Text="For your security, we turned it off after changes were made to the fingerprint, face or iris settings on your device." />
                    <elements:ResponsiveParagraph Text="Log in using your email, password and security code." />

                    <elements:ResponsiveHeading2 Text="Turning fingerprint, face or iris on"/>
                    <elements:ResponsiveUnorderedList>
                        <StackLayout>
                            <elements:ResponsiveListItem Text="Log in to the NHS App." />

                            <elements:ResponsiveListItem Text="Select More, then fingerprint, face or iris." />
                        </StackLayout>
                    </elements:ResponsiveUnorderedList>

                    <elements:ResponsiveLinkLabel Text="Back to login"
                                                  Command="{Binding BackHomeCommand, Source={x:Reference Name=Page}}" />
                </StackLayout>
            </panels:NhsResponsiveContentPanel>
        </StackLayout>
    </ScrollView>
</pages:NhsAppCloseAndLogoHeaderPage>