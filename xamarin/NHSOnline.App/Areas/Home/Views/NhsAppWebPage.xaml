<?xml version="1.0" encoding="utf-8" ?>
<pages:NhsAppFullHeaderPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:d="http://xamarin.com/schemas/2014/forms/design"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:webViews="clr-namespace:NHSOnline.App.Controls.WebViews;assembly=NHSOnline.App.Controls"
             xmlns:pages="clr-namespace:NHSOnline.App.Navigation.Pages;assembly=NHSOnline.App"
             mc:Ignorable="d"
             x:Class="NHSOnline.App.Areas.Home.Views.NhsAppWebPage">

    <webViews:NhsAppWebView x:Name="WebView"
                            VerticalOptions="FillAndExpand"
                            OpenWebIntegrationCommand="{Binding OpenWebIntegrationCommand, Source={RelativeSource AncestorType={x:Type pages:NhsAppFullHeaderPage}}}"
                            GetNotificationsStatusCommand="{Binding GetNotificationsStatusCommand, Source={RelativeSource AncestorType={x:Type pages:NhsAppFullHeaderPage}}}" />
    
</pages:NhsAppFullHeaderPage>
