<?xml version="1.0" encoding="utf-8"?>

<pages:NhsAppPreHomeHeaderPage xmlns="http://xamarin.com/schemas/2014/forms"
                               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                               xmlns:d="http://xamarin.com/schemas/2014/forms/design"
                               xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                               xmlns:pages="clr-namespace:NHSOnline.App.Navigation.Pages;assembly=NHSOnline.App"
                               xmlns:panels="clr-namespace:NHSOnline.App.Controls.Panels;assembly=NHSOnline.App.Controls"
                               mc:Ignorable="d"
                               x:Class="NHSOnline.App.Areas.Errors.Views.PreHomeTryAgainNetworkErrorPage"
                               x:Name="Page">

    <ScrollView BackgroundColor="{StaticResource NhsUkPageBackgroundGrey}">
        <panels:ResponsiveLayoutPanel>
            <panels:TryAgainNetworkError
                x:Name="ErrorPanel"
                TryAgainCommand="{Binding TryAgainCommand, Source={x:Reference Name=Page}}" />
        </panels:ResponsiveLayoutPanel>
    </ScrollView>
</pages:NhsAppPreHomeHeaderPage>