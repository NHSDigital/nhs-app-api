<?xml version="1.0" encoding="utf-8" ?>
<pages:NhsAppCloseSlimHeaderPage xmlns="http://xamarin.com/schemas/2014/forms"
                                 xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                                 xmlns:d="http://xamarin.com/schemas/2014/forms/design"
                                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                                 xmlns:webViews="clr-namespace:NHSOnline.App.Controls.WebViews;assembly=NHSOnline.App.Controls"
                                 xmlns:pages="clr-namespace:NHSOnline.App.Navigation.Pages;assembly=NHSOnline.App"
                                 mc:Ignorable="d"
                                 x:Class="NHSOnline.App.Areas.WebIntegration.Views.NhsLoginUpliftPage"
                                 x:Name="Page">

    <webViews:NhsLoginUpliftWebView x:Name="WebView"
                                    SelectMediaCommand="{Binding SelectMediaCommand, Source={x:Reference Name=Page}}"
                                    VerticalOptions="FillAndExpand" />

</pages:NhsAppCloseSlimHeaderPage>
