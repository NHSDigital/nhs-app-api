<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://xamarin.com/schemas/2014/forms"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:NHSOnline.App.Controls;assembly=NHSOnline.App.Controls"
             x:Class="NHSOnline.App.Navigation.Pages.NhsAppFullHeaderPage"
             x:Name="Root"
             BackgroundColor="{StaticResource NhsUkBlue}">
    <ContentPage.Content>
        <ContentView>
            
            <StackLayout BackgroundColor="{StaticResource NhsUkBlue}" Spacing="0" Padding="0,5,0,0">
                
                <controls:FullNavigationHeader 
                    MoreCommand="{Binding MoreClicked, Source={x:Reference Name=Root}}"
                    HelpCommand="{Binding HelpClicked, Source={x:Reference Name=Root}}"
                    HomeCommand="{Binding HomeClicked, Source={x:Reference Name=Root}}">
                </controls:FullNavigationHeader>
                
                <ContentView 
                    Content="{Binding PageContent, Source={x:Reference Name=Root}}" 
                    VerticalOptions = "FillAndExpand" />
                
                <controls:FullNavigationFooter AdviceCommand="{Binding AdviceClicked, Source={x:Reference Name=Root}}"
                                               AppointmentsCommand="{Binding AppointmentsClicked, Source={x:Reference Name=Root}}"
                                               PrescriptionsCommand="{Binding PrescriptionsClicked, Source={x:Reference Name=Root}}"
                                               YourHealthCommand="{Binding YourHealthClicked, Source={x:Reference Name=Root}}"
                                               MessagesCommand="{Binding MessagesClicked, Source={x:Reference Name=Root}}">
                </controls:FullNavigationFooter>
                
            </StackLayout>
        </ContentView>
    </ContentPage.Content>
</ContentPage>
