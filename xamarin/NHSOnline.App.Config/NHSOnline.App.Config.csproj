<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.1</TargetFramework>
    <Configurations>Local - Debug;Local - Release;Preview - Debug;Preview - Release;Staging - Debug;Staging - Release;BrowserStack - Debug;BrowserStack - Release</Configurations>

    <!-- When restored as a project dependency an invalid configuration ("Debug" or "Release") is supplied -->
    <Environment Condition=" $(Configuration.Contains('-')) == 'true' ">$(Configuration.Split('-')[0].Trim())</Environment>
    <Environment Condition=" $(Configuration.Contains('-')) != 'true' ">Local</Environment>
    <DebugMode Condition=" $(Configuration.Contains('-')) == 'true' ">$(Configuration.Split('-')[1].Trim())</DebugMode>
    <DebugMode Condition=" $(Configuration.Contains('-')) != 'true' ">$(Configuration)</DebugMode>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" Version="3.1.13" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="3.1.12" />
  </ItemGroup>

  <Import Project="Properties/BuildConfiguration.debugmode.$(DebugMode).props" />
  <Import Project="Properties/BuildConfiguration.env.$(Environment).props" />

</Project>
