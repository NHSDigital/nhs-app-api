<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <!-- Info.plist -->

  <PropertyGroup>
    <InfoPlistTemplate>$(MSBuildProjectDirectory)/Info.template.plist</InfoPlistTemplate>
    <InfoPlistGenerated>$(MSBuildProjectDirectory)/Info.plist</InfoPlistGenerated>
    <NSAppTransportSecurityXPath>/plist/dict/dict[preceding-sibling::key[1] = 'NSAppTransportSecurity']</NSAppTransportSecurityXPath>
    <InfoPlistXPath>/plist/dict</InfoPlistXPath>
  </PropertyGroup>

  <Target Name="Generate Info Plist" BeforeTargets="PrepareForBuild">
    <Copy SourceFiles="$(InfoPlistTemplate)" DestinationFiles="$(InfoPlistGenerated)" />

    <XmlPoke
      XmlInputPath="$(InfoPlistGenerated)"
      Value="$(NhsAppBundleIdentifier)"
      Query="/plist/dict/string[preceding-sibling::key[1] = 'CFBundleIdentifier']" />

    <XmlPoke
      XmlInputPath="$(InfoPlistGenerated)"
      Value="$(NhsAppBundleShortVersion)"
      Query="/plist/dict/string[preceding-sibling::key[1] = 'CFBundleShortVersionString']" />

    <XmlPoke
      XmlInputPath="$(InfoPlistGenerated)"
      Value="$(NhsAppBundleVersion)"
      Query="/plist/dict/string[preceding-sibling::key[1] = 'CFBundleVersion']" />

    <XmlPoke
      XmlInputPath="$(InfoPlistGenerated)"
      Value="$(NhsAppBundleDisplayName)"
      Query="/plist/dict/string[preceding-sibling::key[1] = 'CFBundleDisplayName']" />

    <CallTarget Targets="Update Info Plist Allow Insecure Websites" Condition=" '$(NhsAppAllowInsecureBitraftDomain)' == 'true' " />

    <CallTarget Targets="Update Info Plist Allow File sharing" Condition=" '$(NhsAppUIFileSharingEnabled)' == 'true' " />

    <ReadLinesFromFile File="$(InfoPlistGenerated)">
      <Output TaskParameter="Lines" ItemName="InfoPlistLines" />
    </ReadLinesFromFile>
    <Message Text="@(InfoPlistLines, '&#xA;')" Importance="High" />
  </Target>

  <Target Name="Update Info Plist Allow Insecure Websites">
    <!-- Read current NSAppTransportSecurity so we can append to it -->
    <XmlPeek XmlInputPath="$(InfoPlistGenerated)" Query="$(NSAppTransportSecurityXPath)/*">
      <Output TaskParameter="Result" ItemName="TemplateNSAppTransportSecurityContents" />
    </XmlPeek>

    <PropertyGroup>
      <TemplateNSAppTransportSecurityContents>@(TemplateNSAppTransportSecurityContents, '')</TemplateNSAppTransportSecurityContents>
      <AdditionalNSAppTransportSecurityContents>
        <key xmlns="">NSExceptionDomains</key>
        <dict xmlns="">
          <key>local.bitraft.io</key>
          <dict>
            <key>NSIncludesSubdomains</key>
            <true />
            <key>NSExceptionAllowsInsecureHTTPLoads</key>
            <true />
          </dict>
        </dict>
      </AdditionalNSAppTransportSecurityContents>
    </PropertyGroup>

    <XmlPoke
      XmlInputPath="$(InfoPlistGenerated)"
      Query="$(NSAppTransportSecurityXPath)"
      Value="$(TemplateNSAppTransportSecurityContents)$(AdditionalNSAppTransportSecurityContents)" />
  </Target>

  <Target Name="Update Info Plist Allow File sharing">
    <XmlPeek XmlInputPath="$(InfoPlistGenerated)" Query="$(InfoPlistXPath)/*">
      <Output TaskParameter="Result" ItemName="TemplateInfoPlistContents" />
    </XmlPeek>

    <PropertyGroup>
      <TemplateInfoPlistContents>@(TemplateInfoPlistContents, '')</TemplateInfoPlistContents>
      <AdditionalUIFileSharingEnabledContents>
        <key xmlns="">UIFileSharingEnabled</key>
        <true xmlns="" />
      </AdditionalUIFileSharingEnabledContents>
    </PropertyGroup>

    <XmlPoke
      XmlInputPath="$(InfoPlistGenerated)"
      Query="$(InfoPlistXPath)"
      Value="$(TemplateInfoPlistContents)$(AdditionalUIFileSharingEnabledContents)" />
  </Target>

  <!-- End Info.plist -->

  <!-- Entitlements.plist -->

  <PropertyGroup>
    <EntitlementsPlistTemplate>$(MSBuildProjectDirectory)/Entitlements.template.plist</EntitlementsPlistTemplate>
    <EntitlementsPlistGenerated>$(MSBuildProjectDirectory)/Entitlements.plist</EntitlementsPlistGenerated>
  </PropertyGroup>

  <Target Name="Generate Entitlements Plist" BeforeTargets="PrepareForBuild">
    <Copy SourceFiles="$(EntitlementsPlistTemplate)" DestinationFiles="$(EntitlementsPlistGenerated)" />

    <XmlPoke
      XmlInputPath="$(EntitlementsPlistGenerated)"
      Value="$(NhsAppBundleIdentifier)"
      Query="/plist/dict/array[preceding-sibling::key[1] = 'keychain-access-groups']/string[1]" />

    <ReadLinesFromFile File="$(EntitlementsPlistGenerated)">
      <Output TaskParameter="Lines" ItemName="EntitlementsPlistLines" />
    </ReadLinesFromFile>
    <Message Text="@(EntitlementsPlistLines, '&#xA;')" Importance="High" />
  </Target>

  <!-- End Entitlements.plist -->

</Project>