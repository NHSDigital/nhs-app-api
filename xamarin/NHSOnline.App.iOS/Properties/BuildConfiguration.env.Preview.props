<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <IpaPackageName>NHSOnline.App.Preview.ipa</IpaPackageName>
    <NhsAppBundleIdentifier>com.nhs.online.dev.preview</NhsAppBundleIdentifier>
    <NhsAppBundleDisplayName>NHS App Preview</NhsAppBundleDisplayName>
    <NhsAppApnsEnvironmentEntitlement>development</NhsAppApnsEnvironmentEntitlement>
    <NhsAppDomainEntitlement>www-preview.dev.nonlive.nhsapp.service.nhs.uk?mode=developer</NhsAppDomainEntitlement>
    <NhsAppErsDomainEntitlement>pat.rc.refer.nhs.uk</NhsAppErsDomainEntitlement>
  </PropertyGroup>
</Project>
