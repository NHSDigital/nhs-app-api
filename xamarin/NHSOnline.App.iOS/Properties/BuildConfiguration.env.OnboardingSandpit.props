<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <IpaPackageName>NHSOnline.App.OnboardingSandpit.ipa</IpaPackageName>
    <NhsAppBundleIdentifier>com.nhs.online.dev.onboardingsandpit</NhsAppBundleIdentifier>
    <NhsAppBundleDisplayName>NHS App OnboardingSandpit</NhsAppBundleDisplayName>
    <NhsAppApnsEnvironmentEntitlement>production</NhsAppApnsEnvironmentEntitlement>
    <NhsAppDomainEntitlement>www-onboardingsandpit.nhsapp.service.nhs.uk</NhsAppDomainEntitlement>
    <NhsAppErsDomainEntitlement>pat.rc.refer.nhs.uk</NhsAppErsDomainEntitlement>
  </PropertyGroup>
</Project>
