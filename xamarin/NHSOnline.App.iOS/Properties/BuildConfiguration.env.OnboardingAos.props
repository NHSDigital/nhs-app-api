<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <IpaPackageName>NHSOnline.App.OnboardingAos.ipa</IpaPackageName>
    <NhsAppBundleIdentifier>com.nhs.online.dev.onboardingsaos</NhsAppBundleIdentifier>
    <NhsAppBundleDisplayName>NHS App OnboardingAos</NhsAppBundleDisplayName>
    <NhsAppApnsEnvironmentEntitlement>production</NhsAppApnsEnvironmentEntitlement>
    <NhsAppDomainEntitlement>www-onboardingaos.nhsapp.service.nhs.uk</NhsAppDomainEntitlement>
    <NhsAppErsDomainEntitlement>pat.sa.refer.nhs.uk</NhsAppErsDomainEntitlement>
  </PropertyGroup>
</Project>
