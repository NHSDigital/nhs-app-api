{
  "name": "nhsonline-web",
  "version": "1.0.0",
  "private": true,
  "description": "NHS Online Web",
  "main": "index.js",
  "scripts": {
    "build": "npm run swagger-node && npm run transpile && nuxt build",
    "dev": "npm run swagger-node && npm run transpile && nuxt",
    "generate": "npm run swagger-node && nuxt generate",
    "lint-raw": "eslint --max-warnings 0 --ext .js,.vue src test nuxt.config.js",
    "lint": "npm run transpile && npm run lint-raw",
    "lintfix": "npm run transpile && eslint --fix --ext .js,.vue .",
    "start": "nuxt start",
    "test": "npm run swagger-node && npm run lint && jest",
    "test-watch": "jest --watchAll",
    "test-jest": "jest",
    "transpile": "./node_modules/.bin/babel --out-dir src/.transpiled ./src",
    "swagger-node": "node build/swaggerNode.js --handlebars_path ./handlebarExtensions.js --contract_path ../contracts/index.yaml --output_path ../src/services/ --nhsonline_templates_path ./swagger-templates/nhsonline/"
  },
  "precommit": "npm run lint",
  "author": "",
  "license": "ISC",
  "jest": {
    "verbose": true,
    "collectCoverage": true,
    "coverageReporters": [
      "html",
      "cobertura"
    ],
    "reporters": [
      "default",
      "jest-junit"
    ],
    "coverageDirectory": "test/unit/coverage",
    "moduleFileExtensions": [
      "js",
      "vue"
    ],
    "setupFiles": [
      "<rootDir>/test/setup.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/test/setupTests.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/prod_node_modules/"
    ],
    "transform": {
      "^.+\\.js$": "<rootDir>/node_modules/babel-jest",
      ".*\\.(vue)$": "<rootDir>/node_modules/jest-vue-preprocessor"
    },
    "moduleNameMapper": {
      "@/routes$": "<rootDir>/src/lib/routes",
      "@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "jest-junit": {
    "outputDirectory": ".",
    "outputName": "./junit.xml"
  },
  "vue": {
    "prettify": false
  },
  "dependencies": {
    "@babel/polyfill": "7.2.5",
    "ajv": "6.10.0",
    "ajv-keywords": "3.4.0",
    "axios": "0.18.1",
    "babel-eslint": "10.0.1",
    "babel-jest": "24.5.0",
    "body-parser": "1.18.3",
    "busboy": "0.3.1",
    "circular-json": "0.5.9",
    "consola": "2.11.3",
    "cookie": "0.3.1",
    "cookie-universal": "2.0.14",
    "cookie-universal-nuxt": "2.0.14",
    "crypto": "1.0.1",
    "deepmerge": "3.2.0",
    "express": "4.16.4",
    "find-babel-config": "1.2.0",
    "focus-trap": "5.0.1",
    "javascript-natural-sort": "0.7.1",
    "js-cookie": "2.2.0",
    "js-yaml": "3.13.1",
    "linkify-it": "2.2.0",
    "lodash": "4.17.15",
    "minimist": "1.2.0",
    "moment": "2.24.0",
    "moment-timezone": "0.5.23",
    "nhsuk-frontend": "2.0.0",
    "nuxt": "2.11.0",
    "qs": "6.6.0",
    "querystring": "0.2.0",
    "semver": "6.3.0",
    "swagger-node-codegen": "1.6.3",
    "uuid": "3.3.2",
    "vue-i18n": "8.9.0",
    "vue-jest": "3.0.4",
    "vue-scrollto": "2.14.0",
    "vuelidate": "0.7.4",
    "vuex": "3.1.2",
    "vuex-persist": "2.0.0",
    "vuex-persistedstate": "2.5.4",
    "webpack": "4.42.0"
  },
  "devDependencies": {
    "@babel/cli": "7.2.3",
    "@babel/core": "7.3.4",
    "@babel/plugin-syntax-dynamic-import": "7.8.3",
    "@babel/plugin-transform-regenerator": "7.3.4",
    "@babel/plugin-transform-runtime": "7.3.4",
    "@babel/preset-env": "7.3.4",
    "@babel/register": "7.0.0",
    "@types/jest": "24.0.11",
    "@vue/test-utils": "1.0.0-beta.29",
    "avoriaz": "6.3.0",
    "babel-core": "7.0.0-bridge.0",
    "babel-loader": "8.0.5",
    "babel-plugin-root-import": "6.1.0",
    "eslint": "5.15.2",
    "eslint-config-airbnb-base": "13.1.0",
    "eslint-config-logux": "27.0.0",
    "eslint-config-standard": "12.0.0",
    "eslint-friendly-formatter": "4.0.1",
    "eslint-import-resolver-webpack": "0.11.0",
    "eslint-loader": "2.1.2",
    "eslint-plugin-custom": "file:./lint",
    "eslint-plugin-es5": "1.3.1",
    "eslint-plugin-import": "2.16.0",
    "eslint-plugin-jest": "22.4.1",
    "eslint-plugin-node": "8.0.1",
    "eslint-plugin-promise": "4.0.1",
    "eslint-plugin-security": "1.4.0",
    "eslint-plugin-standard": "4.0.0",
    "eslint-plugin-vue": "5.2.2",
    "fs": "0.0.2",
    "glob": "7.1.3",
    "jest": "24.5.0",
    "jest-each": "24.5.0",
    "jest-junit": "7.0.0",
    "jest-serializer-vue": "2.0.2",
    "jest-vue-preprocessor": "1.5.0",
    "mockdate": "2.0.5",
    "node-glob": "1.2.0",
    "node-sass": "4.13.1",
    "sass-loader": "7.1.0"
  }
}
