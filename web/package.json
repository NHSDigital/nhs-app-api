{
  "name": "nhsonline-web",
  "version": "1.0.0",
  "private": true,
  "description": "NHS Online Web",
  "author": "",
  "scripts": {
    "serve": "vue-cli-service serve",
    "build": "npm run build-bundle && npm run vue-build",
    "lint": "npm run transpile-eslint && eslint --max-warnings 0 --ext .js,.vue src test && echo 'Linting complete: no issues found'",
    "audit": "auditjs ossi --q",
    "build-bundle": "npm run swagger-node && npm run bundle-static",
    "build-docker-env": "node build/envBuilder.js --docker",
    "build-env": "node build/envBuilder.js",
    "bundle-static": "webpack",
    "dev": "npm run build-env && npm run start-dev",
    "docker-dev": "npm run build-docker-env && npm run start-dev",
    "inspect": "vue-cli-service inspect",
    "lintfix": "npm run transpile-eslint && eslint --fix --ext .js,.vue .",
    "outdated": "npm outdated || printf '\\nWARN: Outdated packages detected\\n\\n'",
    "shell": "$SHELL",
    "start-dev": "npm run build-bundle && npm run serve",
    "swagger-node": "node build/swaggerNode.js --handlebars_path ./handlebarExtensions.js --contract_path ../contracts/index.yaml --output_path ../src/services/ --nhsonline_templates_path ./swagger-templates/nhsonline/",
    "test": "npm run swagger-node && npm run lint && jest",
    "test-jest": "jest",
    "test-watch": "jest --watchAll",
    "transpile": "./node_modules/.bin/babel --out-dir src/.transpiled ./src",
    "transpile-eslint": "./node_modules/.bin/babel ./src/store/modules/serviceJourneyRules/constants.js --out-dir ./lint/.transpiled --config-file ./babel.config.js",
    "vue-build": "vue-cli-service build --mode=production",
    "vue-upgrade": "vue upgrade"
  },
  "main": "index.js",
  "dependencies": {
    "axios": "0.21.2",
    "babel-jest": "26.0.1",
    "core-js": "2.6.5",
    "deepmerge": "3.2.0",
    "focus-trap": "5.0.1",
    "jwt-decode": "2.2.0",
    "linkify-it": "2.2.0",
    "lodash": "4.17.21",
    "markdown-it": "12.3.2",
    "mime": "2.4.4",
    "minimist": "1.2.6",
    "moment": "2.29.2",
    "moment-timezone": "0.5.23",
    "sanitize-filename": "1.6.3",
    "semver": "6.3.0",
    "swagger-node-codegen": "1.6.3",
    "url-polyfill": "1.1.9",
    "uuid": "3.3.2",
    "vue": "2.6.11",
    "vue-cookies": "1.7.0",
    "vue-i18n": "8.9.0",
    "vue-meta": "2.3.4",
    "vue-router": "3.1.6",
    "vue-scrollto": "2.14.0",
    "vuex": "3.1.3",
    "webpack": "5.72.1"
  },
  "devDependencies": {
    "@babel/cli": "7.2.3",
    "@babel/core": "7.3.4",
    "@babel/plugin-syntax-dynamic-import": "7.8.3",
    "@babel/plugin-transform-runtime": "7.3.4",
    "@babel/preset-env": "7.3.4",
    "@vue/cli-plugin-babel": "~5.0.4",
    "@vue/cli-service": "~5.0.4",
    "@vue/test-utils": "1.0.0-beta.29",
    "ajv": "6.12.3",
    "babel-eslint": "10.1.0",
    "babel-loader": "8.0.5",
    "buffer": "6.0.3",
    "crypto-browserify": "3.12.0",
    "eslint": "5.15.2",
    "eslint-config-airbnb-base": "13.1.0",
    "eslint-config-logux": "27.0.0",
    "eslint-config-standard": "12.0.0",
    "eslint-friendly-formatter": "4.0.1",
    "eslint-plugin-custom": "file:./lint",
    "eslint-plugin-import": "2.22.0",
    "eslint-plugin-jest": "22.4.1",
    "eslint-plugin-node": "8.0.1",
    "eslint-plugin-promise": "4.2.1",
    "eslint-plugin-security": "1.4.0",
    "eslint-plugin-standard": "4.0.1",
    "eslint-plugin-vue": "6.2.2",
    "glob": "7.1.3",
    "javascript-natural-sort": "0.7.1",
    "jest": "26.0.1",
    "jest-each": "26.0.1",
    "jest-junit": "7.0.0",
    "jest-vue-preprocessor": "1.7.1",
    "mockdate": "2.0.5",
    "nhsuk-frontend": "2.0.0",
    "process": "0.11.10",
    "q": "1.5.1",
    "querystring-es3": "0.2.1",
    "sass": "1.26.7",
    "sass-loader": "9.0.2",
    "stream-browserify": "3.0.0",
    "tmpl": "1.0.5",
    "typescript": "3.4.3",
    "vue-style-loader": "4.1.2",
    "vue-template-compiler": "2.6.11",
    "webpack-cli": "4.9.2"
  },
  "vue": {
    "assetsDir": "dev_web_npm"
  },
  "jest": {
    "verbose": true,
    "collectCoverage": true,
    "coverageReporters": [
      "html",
      "cobertura"
    ],
    "reporters": [
      "default",
      "jest-junit"
    ],
    "coverageDirectory": "test/unit/coverage",
    "moduleFileExtensions": [
      "js",
      "vue"
    ],
    "setupFiles": [
      "<rootDir>/test/setup.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/test/setupTests.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/prod_node_modules/"
    ],
    "transform": {
      "^.+\\.js$": "<rootDir>/node_modules/babel-jest",
      ".*\\.(vue)$": "<rootDir>/node_modules/jest-vue-preprocessor"
    },
    "moduleNameMapper": {
      "@/routes$": "<rootDir>/src/lib/routes",
      "@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "jest-junit": {
    "outputDirectory": ".",
    "outputName": "./junit.xml"
  },
  "license": "ISC",
  "precommit": "npm run lint"
}
