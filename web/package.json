{
  "name": "nhsonline-web",
  "version": "1.0.0",
  "private": true,
  "description": "NHS Online Web",
  "main": "index.js",
  "scripts": {
    "dev": "npm run transpile && npm run swagger && nuxt",
    "transpile-middleware": "npx babel --out-dir src/.transpiled/middleware-server ./src/middleware-server",
    "transpile-services": "npx babel --out-dir src/.transpiled/services ./src/services",
    "transpile": "npx babel --out-dir src/.transpiled ./src",
    "build": "npm run swagger && npm run transpile && nuxt build",
    "start": "nuxt start",
    "swagger": "node build/swagger.js --contract_path contracts/index.yaml --output_path src/services/nhsonlineapi.js && npx babel --out-file ./src/.transpiled/services/nhsonlineapi.js ./src/services/nhsonlineapi.js ",
    "test": "npm run swagger && npm run lint && jest",
    "test-watch": "jest --watchAll",
    "lint": "eslint --ext .js,.vue src test nuxt.config.js",
    "lintfix": "eslint --fix --ext .js,.vue .",
    "generate": "npm run swagger && nuxt generate"
  },
  "precommit": "npm run lint",
  "author": "",
  "license": "ISC",
  "jest": {
    "verbose": true,
    "collectCoverage": true,
    "coverageReporters": [
      "teamcity",
      "html"
    ],
    "coverageDirectory": "test/unit/coverage",
    "moduleFileExtensions": [
      "js",
      "vue"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/prod_node_modules/"
    ],
    "transform": {
      "^.+\\.js$": "<rootDir>/node_modules/babel-jest",
      ".*\\.(vue)$": "<rootDir>/node_modules/jest-vue-preprocessor"
    },
    "moduleNameMapper": {
      "@/routes$": "<rootDir>/src/lib/routes",
      "@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "dependencies": {
    "ajv": "6.5.0",
    "ajv-keywords": "3.2.0",
    "axios": "0.18.0",
    "babel-core": "6.26.3",
    "babel-eslint": "8.2.3",
    "babel-helper-vue-jsx-merge-props": "2.0.3",
    "babel-jest": "22.4.3",
    "babel-loader": "7.1.1",
    "babel-plugin-dynamic-import-node": "1.2.0",
    "babel-plugin-transform-es2015-modules-commonjs": "6.26.2",
    "babel-plugin-transform-runtime": "6.23.0",
    "babel-plugin-transform-vue-jsx": "3.7.0",
    "babel-polyfill": "6.26.0",
    "babel-preset-env": "1.7.0",
    "babel-preset-es2015": "6.24.1",
    "babel-preset-stage-2": "6.24.1",
    "babel-register": "6.22.0",
    "body-parser": "1.18.3",
    "circular-json": "0.5.3",
    "consola": "1.4.3",
    "cookie": "0.3.1",
    "cookie-universal": "2.0.5",
    "cookie-universal-nuxt": "2.0.3",
    "deepmerge": "2.1.0",
    "crypto": "1.0.1",
    "express": "4.16.4",
    "js-cookie": "2.2.0",
    "js-yaml": "3.11.0",
    "lodash": "4.17.10",
    "minimist": "1.2.0",
    "moment": "2.22.1",
    "moment-timezone": "0.5.21",
    "node-sass": "4.9.3",
    "nuxt": "1.4.1",
    "qs": "6.5.2",
    "querystring": "0.2.0",
    "sass-loader": "7.0.1",
    "swagger-js-codegen": "1.12.0",
    "vee-validate": "2.0.9",
    "vue-i18n": "7.6.0",
    "vue-jest": "2.5.0",
    "vue-scrollto": "2.11.0",
    "vuelidate": "0.7.4",
    "vuex": "3.0.1",
    "vuex-persist": "1.2.2",
    "vuex-persistedstate": "2.5.2"
  },
  "devDependencies": {
    "@types/jest": "22.2.3",
    "@vue/test-utils": "1.0.0-beta.16",
    "avoriaz": "6.3.0",
    "babel-cli": "6.26.0",
    "babel-plugin-root-import": "6.1.0",
    "babel-preset-node8": "1.2.0",
    "eslint": "4.19.1",
    "eslint-config-airbnb-base": "12.1.0",
    "eslint-config-logux": "23.0.0",
    "eslint-config-standard": "11.0.0",
    "eslint-friendly-formatter": "3.0.0",
    "eslint-import-resolver-webpack": "0.8.3",
    "eslint-loader": "2.0.0",
    "eslint-plugin-es5": "1.3.1",
    "eslint-plugin-import": "2.12.0",
    "eslint-plugin-jest": "21.17.0",
    "eslint-plugin-node": "6.0.1",
    "eslint-plugin-promise": "3.8.0",
    "eslint-plugin-security": "1.4.0",
    "eslint-plugin-standard": "3.1.0",
    "eslint-plugin-vue": "4.5.0",
    "fs": "0.0.1-security",
    "jest": "22.4.3",
    "jest-each": "23.2.0",
    "jest-serializer-vue": "1.0.0",
    "jest-vue-preprocessor": "1.4.0",
    "regenerator-runtime": "0.13.1"
  }
}
