{
  "name": "nhsonline-web",
  "version": "1.0.0",
  "private": true,
  "description": "NHS Online Web",
  "main": "index.js",
  "scripts": {
    "build": "npm run swagger && npm run transpile && nuxt build",
    "dev": "npm run swagger && npm run transpile && nuxt",
    "generate": "npm run swagger && nuxt generate",
    "lint": "eslint --ext .js,.vue src test nuxt.config.js",
    "lintfix": "eslint --fix --ext .js,.vue .",
    "start": "nuxt start",
    "swagger": "node build/swagger.js --contract_path contracts/index.yaml --output_path src/services/nhsonlineapi.js",
    "test": "npm run swagger && npm run lint && jest",
    "test-watch": "jest --watchAll",
    "test-jest": "jest",
    "transpile": "./node_modules/.bin/babel --out-dir src/.transpiled ./src"
  },
  "precommit": "npm run lint",
  "author": "",
  "license": "ISC",
  "jest": {
    "verbose": true,
    "collectCoverage": true,
    "coverageReporters": [
      "teamcity",
      "html"
    ],
    "coverageDirectory": "test/unit/coverage",
    "moduleFileExtensions": [
      "js",
      "vue"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/prod_node_modules/"
    ],
    "transform": {
      "^.+\\.js$": "<rootDir>/node_modules/babel-jest",
      ".*\\.(vue)$": "<rootDir>/node_modules/jest-vue-preprocessor"
    },
    "moduleNameMapper": {
      "@/routes$": "<rootDir>/src/lib/routes",
      "@/(.*)$": "<rootDir>/src/$1"
    }
  },
  "dependencies": {
    "@babel/polyfill": "7.2.5",
    "ajv": "6.10.0",
    "ajv-keywords": "3.4.0",
    "axios": "0.18.0",
    "babel-eslint": "10.0.1",
    "babel-jest": "24.5.0",
    "body-parser": "1.18.3",
    "circular-json": "0.5.9",
    "consola": "2.5.6",
    "cookie": "0.3.1",
    "cookie-universal": "2.0.14",
    "cookie-universal-nuxt": "2.0.14",
    "crypto": "1.0.1",
    "deepmerge": "3.2.0",
    "express": "4.16.4",
    "find-babel-config": "1.2.0",
    "javascript-natural-sort": "0.7.1",
    "js-cookie": "2.2.0",
    "js-yaml": "3.12.2",
    "lodash": "4.17.11",
    "minimist": "1.2.0",
    "moment": "2.24.0",
    "moment-timezone": "0.5.23",
    "nhsuk-frontend": "2.0.0",
    "nuxt": "2.4.5",
    "qs": "6.6.0",
    "querystring": "0.2.0",
    "swagger-js-codegen": "1.12.0",
    "vee-validate": "2.1.7",
    "vue-i18n": "8.9.0",
    "vue-jest": "3.0.4",
    "vue-scrollto": "2.14.0",
    "vuelidate": "0.7.4",
    "vuex": "3.1.0",
    "vuex-persist": "2.0.0",
    "vuex-persistedstate": "2.5.4"
  },
  "devDependencies": {
    "@babel/cli": "7.2.3",
    "@babel/core": "7.3.4",
    "@babel/plugin-syntax-dynamic-import": "7.2.0",
    "@babel/plugin-transform-regenerator": "7.3.4",
    "@babel/plugin-transform-runtime": "7.3.4",
    "@babel/preset-env": "7.3.4",
    "@babel/register": "7.0.0",
    "@types/jest": "24.0.11",
    "@vue/test-utils": "1.0.0-beta.16",
    "avoriaz": "6.3.0",
    "babel-core": "7.0.0-bridge.0",
    "babel-loader": "8.0.5",
    "babel-plugin-root-import": "6.1.0",
    "eslint": "5.15.2",
    "eslint-config-airbnb-base": "13.1.0",
    "eslint-config-logux": "27.0.0",
    "eslint-config-standard": "12.0.0",
    "eslint-friendly-formatter": "4.0.1",
    "eslint-import-resolver-webpack": "0.11.0",
    "eslint-loader": "2.1.2",
    "eslint-plugin-es5": "1.3.1",
    "eslint-plugin-import": "2.16.0",
    "eslint-plugin-jest": "22.4.1",
    "eslint-plugin-node": "8.0.1",
    "eslint-plugin-promise": "4.0.1",
    "eslint-plugin-security": "1.4.0",
    "eslint-plugin-standard": "4.0.0",
    "eslint-plugin-vue": "5.2.2",
    "fs": "0.0.2",
    "jest": "24.5.0",
    "jest-each": "24.5.0",
    "jest-serializer-vue": "2.0.2",
    "jest-vue-preprocessor": "1.5.0",
    "node-sass": "4.11.0",
    "sass-loader": "7.1.0",
    "webpack": "4.29.6"
  }
}
